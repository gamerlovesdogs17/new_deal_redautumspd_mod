# = Public Opinion

@strategic_dashboard
title: Strategic Dashboard
on-arrival: {!
function coloredEstimate(label, color) {
    return '<span style="color:' + color + ';font-weight:bold">' + label + '</span>';
}
function pressureEstimate(value, guarded, high, critical) {
    value = value || 0;
    if (value >= critical) return coloredEstimate("critical", "#c62828");
    if (value >= high) return coloredEstimate("high", "#d97706");
    if (value >= guarded) return coloredEstimate("guarded", "#b58900");
    return coloredEstimate("low", "#2e7d32");
}
function capacityEstimate(value) {
    value = value || 0;
    if (value >= 7) return coloredEstimate("deep", "#2e7d32");
    if (value >= 4) return coloredEstimate("strong", "#2e7d32");
    if (value >= 2) return coloredEstimate("developing", "#b58900");
    return coloredEstimate("limited", "#c62828");
}
function confidenceEstimate(value) {
    value = value || 0;
    if (value >= 65) return coloredEstimate("strong", "#2e7d32");
    if (value >= 45) return coloredEstimate("steady", "#b58900");
    if (value >= 30) return coloredEstimate("shaky", "#d97706");
    return coloredEstimate("weak", "#c62828");
}
function legitimacyEstimate(value) {
    value = value || 0;
    if (value >= 65) return coloredEstimate("broad", "#2e7d32");
    if (value >= 45) return coloredEstimate("contested", "#b58900");
    if (value >= 30) return coloredEstimate("thin", "#d97706");
    return coloredEstimate("collapsing", "#c62828");
}
Q.banking_confidence_display = confidenceEstimate(Q.banking_confidence);
Q.new_deal_legitimacy_display = legitimacyEstimate(Q.new_deal_legitimacy);
Q.economic_stress_display = pressureEstimate(Q.economic_stress, 6, 12, 18);
Q.labor_militancy_display = pressureEstimate(Q.labor_militancy, 3, 6, 9);
Q.conservative_backlash_display = pressureEstimate(Q.conservative_backlash, 4, 8, 12);
Q.radical_momentum_display = pressureEstimate(Q.radical_momentum, 10, 20, 30);
Q.supreme_court_hostility_display = pressureEstimate(Q.supreme_court_hostility, 2, 5, 8);
Q.opposition_pressure_display = pressureEstimate(Q.opposition_pressure, 2, 5, 8);
Q.liberty_litigation_display = pressureEstimate(Q.liberty_litigation, 2, 5, 8);
Q.gop_obstruction_display = pressureEstimate(Q.gop_obstruction, 2, 5, 8);
Q.radio_reach_display = capacityEstimate(Q.radio_reach);
Q.governor_network_display = capacityEstimate(Q.governor_network);
Q.farm_relief_display = capacityEstimate(Q.farm_relief);
Q.agency_capacity_display = capacityEstimate(Q.agency_capacity);
Q.cabinet_style_display = Q.cabinet_style || "regular";
Q.committee_control_display = capacityEstimate(Q.committee_control);
Q.house_whip_operation_display = capacityEstimate(Q.house_whip_operation);
Q.senate_whip_operation_display = capacityEstimate(Q.senate_whip_operation);
Q.pork_barrel_pressure_display = pressureEstimate(Q.pork_barrel_pressure, 2, 5, 8);
Q.capital_strike_display = pressureEstimate(Q.capital_strike_progress, 2, 6, 9);
Q.coup_risk_display = pressureEstimate(Q.coup_progress, 2, 6, 9);
!}

