title: Congressional Elections
new-page: true
tags: event
priority: -1
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year)
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 2; n_elections += 1; next_election_time = time + 24; papen_speaker_timer = 4;
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

# TODO: should there be an image?

# the low priority means that this event is only seen after all other events are resolved for the month.

= Congressional Elections, [+ month : month +] [+ year +]

House and Senate elections are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48. This is likely to be extremely unpopular both with our base and with the other parties. However, this may be necessary to prevent the extremists from gaining power.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-departure: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; dvp_relation -= 8; z_relation -= 8; ddp_relation -= 10; kpd_relation -= 8; coup_progress += 2; workers_spd -= 4; new_middle_spd -= 5; old_middle_spd -= 5; rural_spd -= 5; catholics_spd -= 5; unemployed_spd -= 5; coup_progress += 2 if nsdap_normalized >= 0.3; coup_progress += 2 if nsdap_normalized + dnvp_normalized >= 0.5; sa_strength += 100 if coup_progress >= 7; sh_strength += 100 if coup_progress >= 7
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

Let us hope this does not backfire.

@post_election_1928
on-arrival: {!
// set old results
// election threshold constitutional reform
// banning parties
var new_party_sum = 0;
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'];
    if (Q.constitutional_reform > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || (Q.electoral_threshold > 1 && party == 'other') || Q[party + '_banned']) {
            Q[party + '_r'] = 0;
        } else {
            Q[party + '_r'] = Q[party + '_votes'];
        }
        new_party_sum += Q[party + '_r'];
    } else {
        Q[party + '_r'] = Q[party + '_votes'];
    }
    // if we use decimals, then we might want to truncate the numbers
    if (Q.use_decimals) {
        Q[party + '_r_disp'] = Q[party+'_r'].toFixed(1);
    }  else {
            Q[party + '_r_disp'] = Q[party+'_r'];
    }
    Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
    var sign = Q['change_' + party + '_r'] > 0 ? '+'  : '';
    Q['str_change_' + party] = sign + Q['change_' + party + '_r'];//.toFixed(1);
}
// calculate new party sum if electoral reform
if (Q.electoral_threshold && Q.electoral_threshold > 0) {
    for (var party of Q.parties) {
        if (Q[party + '_r'] > 0) {
            if (Q.use_decimals) {
                Q[party + '_r'] = Math.round(Q[party + '_r']*1000/new_party_sum)/10;
            } else {
                Q[party + '_r'] = Math.round(Q[party + '_r']*100/new_party_sum);
            }
        }
        if (Q.use_decimals) {
            Q[party + '_r_disp'] = Q[party+'_r'].toFixed(1);
        } else {
            Q[party + '_r_disp'] = Q[party+'_r'];
        }
        Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
        var sign = Q['change_' + party + '_r'] > 0 ? '+'  : '';
        Q['str_change_' + party] = sign + Q['change_' + party + '_r'];//.toFixed(1);
    }
}

// get change arrows and signs


// The largest party can only be the NSDAP or the SPD.
Q.largest_party = 'SPD';
if (Q.nsdap_r >= Q.spd_r && Q.nsdap_r >= Q.kpd_r) {
    Q.largest_party = 'NSDAP';
}

if (Q.kpd_r >= Q.spd_r && Q.kpd_r >= Q.nsdap_r) {
    Q.largest_party = 'KPD';
}

// coalitions
Q.weimar_coalition = Q.spd_r + Q.z_r;
Q.grand_coalition = Q.spd_r + Q.z_r + Q.dvp_r;
Q.bourgeois_coalition = Q.ddp_r + Q.z_r + Q.dvp_r + Q.other_r;
Q.center_right_coalition = Q.z_r + Q.ddp_r + Q.dvp_r + Q.other_r;
Q.right_coalition = Q.z_r + Q.ddp_r + Q.dvp_r + Q.other_r;
Q.far_right_coalition = Q.dnvp_r + Q.nsdap_r;
Q.left_coalition = Q.spd_r + Q.kpd_r + Q.sapd_r;
// this is an absurd concept lol
Q.popular_front_coalition = Q.spd_r + Q.kpd_r + Q.z_r + Q.sapd_r;
Q.anti_democratic_coalition = Q.kpd_r + Q.nsdap_r + Q.dnvp_r;
// aka everyone except nazi, kpd, dnvp
Q.neo_weimar_coalition = Q.spd_r + Q.ddp_r + Q.z_r + Q.dvp_r;
// Hitler + Right-wing parties (only comes into effect if you've alienated Z too badly)
Q.hitler_right_coalition = Q.z_r + Q.dnvp_r + Q.nsdap_r;
// Progressive coalition isn't going to be implemented as a distinct coalition but it's the coalition that lets you pass improved women's rights/gay rights
Q.progressive_coalition = Q.spd_r + Q.kpd_r + Q.z_r + Q.sapd_r;

// Bicameral model:
// *_r remains the broad national vote baseline.
// We derive separate House and Senate blocs to represent divergent chamber outcomes.
var houseBias = {'spd': 1.04, 'kpd': 1.02, 'z': 0.98, 'ddp': 0.99, 'dvp': 0.97, 'dnvp': 0.96, 'nsdap': 1.03, 'other': 0.96, 'sapd': 1.01};
var senateBias = {'spd': 0.96, 'kpd': 0.88, 'z': 1.08, 'ddp': 1.02, 'dvp': 1.04, 'dnvp': 1.06, 'nsdap': 1.01, 'other': 1.02, 'sapd': 0.9};
var chamberParties = ['spd', 'kpd', 'z', 'ddp', 'dvp', 'dnvp', 'nsdap', 'other'];
if (Q.sapd_formed) {
    chamberParties.push('sapd');
}
var houseSum = 0;
var senateSum = 0;
for (var p of chamberParties) {
    Q[p + '_h'] = Math.max(0, (Q[p + '_r'] || 0) * (houseBias[p] || 1));
    Q[p + '_s'] = Math.max(0, (Q[p + '_r'] || 0) * (senateBias[p] || 1));
    houseSum += Q[p + '_h'];
    senateSum += Q[p + '_s'];
}
for (var p2 of chamberParties) {
    Q[p2 + '_h'] = Math.round(1000 * Q[p2 + '_h'] / houseSum) / 10;
    Q[p2 + '_s'] = Math.round(1000 * Q[p2 + '_s'] / senateSum) / 10;
}
var houseSeatsTotal = 435;
var senateSeatsTotal = 96;
var assignedHouseSeats = 0;
var assignedSenateSeats = 0;
for (var p3 of chamberParties) {
    Q[p3 + '_h_seats'] = Math.round(houseSeatsTotal * Q[p3 + '_h'] / 100);
    Q[p3 + '_s_seats'] = Math.round(senateSeatsTotal * Q[p3 + '_s'] / 100);
    assignedHouseSeats += Q[p3 + '_h_seats'];
    assignedSenateSeats += Q[p3 + '_s_seats'];
}
Q.other_h_seats += houseSeatsTotal - assignedHouseSeats;
Q.other_s_seats += senateSeatsTotal - assignedSenateSeats;
Q.weimar_house = Q.spd_h + Q.z_h;
Q.weimar_senate = Q.spd_s + Q.z_s;
Q.grand_house = Q.spd_h + Q.z_h + Q.dvp_h;
Q.grand_senate = Q.spd_s + Q.z_s + Q.dvp_s;
Q.bourgeois_house = Q.ddp_h + Q.z_h + Q.dvp_h + Q.other_h;
Q.bourgeois_senate = Q.ddp_s + Q.z_s + Q.dvp_s + Q.other_s;
Q.neo_weimar_house = Q.spd_h + Q.ddp_h + Q.z_h + Q.dvp_h;
Q.neo_weimar_senate = Q.spd_s + Q.ddp_s + Q.z_s + Q.dvp_s;
Q.gop_liberty_house = Q.dvp_h + Q.ddp_h + Q.other_h;
Q.gop_liberty_senate = Q.dvp_s + Q.ddp_s + Q.other_s;
Q.fl_defector_house = Math.min(Q.z_h, (Q.gop_wing == "moderate_reform" ? 4 : 2));
Q.fl_defector_senate = Math.min(Q.z_s, (Q.gop_wing == "moderate_reform" ? 3 : 1));
Q.gop_defector_house = Q.gop_liberty_house + Q.fl_defector_house;
Q.gop_defector_senate = Q.gop_liberty_senate + Q.fl_defector_senate;
Q.constitutional_opposition_house = Math.max(Q.gop_liberty_house, Q.gop_defector_house);
Q.constitutional_opposition_senate = Math.max(Q.gop_liberty_senate, Q.gop_defector_senate);
Q.right_house = Q.constitutional_opposition_house;
Q.right_senate = Q.constitutional_opposition_senate;
Q.far_right_house = Q.dnvp_h + Q.nsdap_h;
Q.far_right_senate = Q.dnvp_s + Q.nsdap_s;
Q.left_house = Q.spd_h + Q.kpd_h + (Q.sapd_h || 0);
Q.left_senate = Q.spd_s + Q.kpd_s + (Q.sapd_s || 0);
Q.popular_house = Q.spd_h + Q.kpd_h + Q.z_h + (Q.sapd_h || 0);
Q.popular_senate = Q.spd_s + Q.kpd_s + Q.z_s + (Q.sapd_s || 0);
Q.dem_bill_coalition = Math.max(Q.weimar_senate, Q.grand_senate, Q.popular_senate, Q.left_senate);
Q.best_dem_house = Math.max(Q.spd_h, Q.weimar_house, Q.grand_house, Q.left_house, Q.popular_house);
Q.best_dem_senate = Math.max(Q.spd_s, Q.weimar_senate, Q.grand_senate, Q.left_senate, Q.popular_senate);
Q.non_dem_house = Q.constitutional_opposition_house >= 50 ? Q.constitutional_opposition_house : Math.max(Q.constitutional_opposition_house, Q.far_right_house);
Q.non_dem_senate = Q.constitutional_opposition_senate >= 50 ? Q.constitutional_opposition_senate : Math.max(Q.constitutional_opposition_senate, Q.far_right_senate);
Q.gop_liberty_house_seats = Q.dvp_h_seats + Q.ddp_h_seats + Q.other_h_seats;
Q.gop_liberty_senate_seats = Q.dvp_s_seats + Q.ddp_s_seats + Q.other_s_seats;
Q.gop_defector_house_seats = Q.gop_liberty_house_seats + Math.round(435 * Q.fl_defector_house / 100);
Q.gop_defector_senate_seats = Q.gop_liberty_senate_seats + Math.round(96 * Q.fl_defector_senate / 100);
Q.far_right_house_seats = Q.dnvp_h_seats + Q.nsdap_h_seats;
Q.far_right_senate_seats = Q.dnvp_s_seats + Q.nsdap_s_seats;
Q.non_dem_house_seats = Q.constitutional_opposition_house >= 50 || Q.constitutional_opposition_house >= Q.far_right_house ? Q.gop_defector_house_seats : Q.far_right_house_seats;
Q.non_dem_senate_seats = Q.constitutional_opposition_senate >= 50 || Q.constitutional_opposition_senate >= Q.far_right_senate ? Q.gop_defector_senate_seats : Q.far_right_senate_seats;
Q.non_dem_house_name = Q.constitutional_opposition_house >= 50 || Q.constitutional_opposition_house >= Q.far_right_house ? "Republican-Liberty opposition House bloc" : "NUSJ-Silver Legion House bloc";
Q.non_dem_senate_name = Q.constitutional_opposition_senate >= 50 || Q.constitutional_opposition_senate >= Q.far_right_senate ? "Republican-Liberty opposition Senate bloc" : "NUSJ-Silver Legion Senate bloc";
Q.non_dem_house_desc = Q.constitutional_opposition_house >= 50 || Q.constitutional_opposition_house >= Q.far_right_house ? "Republican Party, Liberty League, independents, and a small number of Farmer-Labor defectors. They oppose the Democratic administration, the Socialist Party of America, NUSJ, and the Silver Legion." : "National Union for Social Justice and Silver Legion-aligned members. They are anti-system forces and can only organize if the constitutional opposition is weaker or fragmented.";
Q.non_dem_senate_desc = Q.constitutional_opposition_senate >= 50 || Q.constitutional_opposition_senate >= Q.far_right_senate ? "Republican Party, Liberty League, independents, and a small number of Farmer-Labor defectors. They oppose the Democratic administration, the Socialist Party of America, NUSJ, and the Silver Legion." : "National Union for Social Justice and Silver Legion-aligned members. They are anti-system forces and can only organize if the constitutional opposition is weaker or fragmented.";
Q.non_dem_house_alternatives = "Republican-Liberty: " + Q.gop_liberty_house + "%; Republican-Liberty with Farmer-Labor defectors: " + Q.gop_defector_house + "%; NUSJ-Silver Legion: " + Q.far_right_house + "%";
Q.non_dem_senate_alternatives = "Republican-Liberty: " + Q.gop_liberty_senate + "%; Republican-Liberty with Farmer-Labor defectors: " + Q.gop_defector_senate + "%; NUSJ-Silver Legion: " + Q.far_right_senate + "%";
Q.non_dem_house_has_majority = Q.non_dem_house >= 50 ? 1 : 0;
Q.non_dem_senate_has_majority = Q.non_dem_senate >= 50 ? 1 : 0;
Q.can_dem_house_coalition = Q.best_dem_house >= 50 ? 1 : 0;
Q.can_dem_senate_coalition = 0;
if (Q.spd_s >= 50 || Q.weimar_senate >= 50 || Q.grand_senate >= 50) {
    Q.can_dem_senate_coalition = 1;
}
if (Q.neo_weimar_senate >= 50 && Q.z_relation >= 50 && Q.dvp_relation >= 30) {
    Q.can_dem_senate_coalition = 1;
}
if (Q.left_senate >= 50 && Q.kpd_relation >= 50 && Q.communist_coalition >= 3) {
    Q.can_dem_senate_coalition = 1;
}
if (Q.popular_senate >= 50 && Q.kpd_relation >= 45 && Q.z_relation >= 45 && Q.communist_coalition >= 3) {
    Q.can_dem_senate_coalition = 1;
}
Q.gridlock_risk = 0;
if (Q.dem_bill_coalition < 50) {
    Q.gridlock_risk = 1;
}

if (Q.kpd_relation >= 30) {
    Q.weimar_coalition += Q.sapd_r;
}

Q.leverage = Q.spd_r;

Q.grand_coalition_failed = 0;
// Reset government and ministers... Based on Brüning's 1930 govt
Q.coalition_dissent = 0;
Q.kpd_coalition_dissent = 0;
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.spd_toleration = 0;
Q.spd_caretaker = 0;
Q.in_right_coalition = 0;
Q.non_dem_house_control = 0;
Q.non_dem_senate_control = 0;
Q.non_dem_congressional_control = 0;
Q.foreign_minister_party = 'DVP';
Q.interior_minister_party = 'Z';
Q.justice_minister_party = 'I';
Q.labor_minister_party = 'Z';
Q.reichswehr_minister_party = 'I';
Q.economic_minister_party = Q.ddp_name;
Q.finance_minister_party = 'DVP';
Q.agriculture_minister_party = 'Z';

// reset KPD goals
Q.kpd_goals_seen = 0;
Q.kpd_ultimatum_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labor_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.reichswehr_goal = 0;

Q.welfare_goal_completed = 0;
Q.agriculture_goal_completed = 0;
Q.economy_goal_completed = 0;
Q.finance_goal_completed = 0;
Q.labor_goal_completed = 0;
Q.foreign_goal_completed = 0;
Q.interior_goal_completed = 0;
Q.reichswehr_goal_completed = 0;

Q.strike_term_seen = 0;

Q.z_minus_bvp_r = Q.z_r - 3;
Q.gop_r = Q.dvp_r;
Q.old_gop_r = Q.old_dvp_r;
Q.change_gop_r = Q.gop_r - Q.old_gop_r;
Q.str_change_gop = (Q.change_gop_r > 0 ? '+' : '') + Q.change_gop_r;
Q.liberty_league_r = Q.ddp_r;
Q.nusj_r = Q.dnvp_r;
Q.silver_legion_r = Q.nsdap_r;
Q.gop_h = Q.dvp_h;
Q.gop_s = Q.dvp_s;
Q.gop_h_seats = Q.dvp_h_seats;
Q.gop_s_seats = Q.dvp_s_seats;
Q.liberty_league_h = Q.ddp_h;
Q.liberty_league_s = Q.ddp_s;
Q.liberty_league_h_seats = Q.ddp_h_seats;
Q.liberty_league_s_seats = Q.ddp_s_seats;
Q.nusj_h = Q.dnvp_h;
Q.nusj_s = Q.dnvp_s;
Q.nusj_h_seats = Q.dnvp_h_seats;
Q.nusj_s_seats = Q.dnvp_s_seats;
Q.silver_legion_h = Q.nsdap_h;
Q.silver_legion_s = Q.nsdap_s;
Q.silver_legion_h_seats = Q.nsdap_h_seats;
Q.silver_legion_s_seats = Q.nsdap_s_seats;

// understanding the enemy
if (Q.nsdap_r >= 15) {
    Q.understanding_enemy_timer = 2;
}

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
on-departure: nazi_urgency = 1 if (nazi_urgency == 0 and nsdap_r >= 15)
on-display: {!
data = [
    {
        "id": "kpd",
        "legend": "Socialist Party of America",
        "name": "Socialist Party of America",
        "seats": Q.kpd_h_seats,
    }
];
if (Q.sapd_formed && Q.sapd_r) {
    data.push({
            "id": "sapd",
            "legend": "SAPD",
            "name": "SAPD",
            "seats": Q.sapd_h_seats,
            });
}
data = data.concat([
    {
        "id": "spd",
        "legend": "Democratic Party",
        "name": "Democratic Party",
        "seats": Q.spd_h_seats,
    },
    {
        "id": "ddp",
        "legend": "Liberty League",
        "name": "Liberty League",
        "seats": Q.liberty_league_h_seats,
    },
    {
        "id": "z",
        "legend": "Farmer-Labor",
        "name": "Farmer-Labor",
        "seats": Q.z_h_seats,
    },
    {
        "id": "dvp",
        "legend": "Republican Party",
        "name": "Republican Party",
        "seats": Q.gop_h_seats,
    },
    {
        "id": "dnvp",
        "legend": "National Union for Social Justice",
        "name": "National Union for Social Justice",
        "seats": Q.nusj_h_seats,
    },
    {
        "id": "nsdap",
        "legend": "Silver Legion",
        "name": "Silver Legion",
        "seats": Q.silver_legion_h_seats,
    },
]);

if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}
go-to: house_coalition_menu

= House election results

{!<svg id="reichstag" style="width: 500px; height: 250px;"> </svg>!}

{!<table>!} 
{!<tr><td>Bloc</td><td>House seats</td><td>House share</td><td>National change</td></tr>!}
{!<tr><td><div class="box" style='background-color:#2f65a8; outline: 2px; outline-style: solid;'> </div> !} **Democratic Party:** {!</td><td>!} **[+ spd_h_seats +]** {!</td><td>!} **[+ spd_h +]%** {!</td><td>!} **[+ str_change_spd +]** {!</td></tr>!}

[? if sapd_formed : {!<tr><td><div class="box" style='background-color:#C40000'> </div> !}SAPD: {!</td><td>!} [+ sapd_r +]% {!</td><td>!} [+ str_change_sapd +] {!</td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#8B0000'> </div> !}Socialist Party of America: {!</td><td>!} [+ kpd_h_seats +] {!</td><td>!} [+ kpd_h +]% {!</td><td>!} [+ str_change_kpd +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#DCCA4A'> </div> !} Liberty League: {!</td><td>!} [+ liberty_league_h_seats +] {!</td><td>!} [+ liberty_league_h +]% {!</td><td>!} [+ str_change_ddp +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#000'> </div> !} Farmer-Labor: {!</td><td>!} [+ z_h_seats +] {!</td><td>!} [+ z_h +]% {!</td><td>!} [+ str_change_z +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#C1121F'> </div> !} Republican Party: {!</td><td>!} [+ gop_h_seats +] {!</td><td>!} [+ gop_h +]% {!</td><td>!} [+ str_change_gop +] {!</td></tr>!}
 
{!<tr><td><div class="box" style='background-color:#954B00'> </div> !} National Union for Social Justice: {!</td><td>!} [+ nusj_h_seats +] {!</td><td>!} [+ nusj_h +]% {!</td><td>!} [+ str_change_dnvp +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#a0a0a0'> </div> !} Silver Legion: {!</td><td>!} [+ silver_legion_h_seats +] {!</td><td>!} [+ silver_legion_h +]% {!</td><td>!} [+ str_change_nsdap +] {!</td></tr>!}
{!</table>!}

**Projected chamber breakdown** (coalitions required in both chambers for reliable governing):

Democratic Party: House [+ spd_h_seats +] seats ([+ spd_h +]%) / Senate [+ spd_s_seats +] seats ([+ spd_s +]%)

Socialist Party of America: House [+ kpd_h_seats +] seats ([+ kpd_h +]%) / Senate [+ kpd_s_seats +] seats ([+ kpd_s +]%)

Farmer-Labor: House [+ z_h_seats +] seats ([+ z_h +]%) / Senate [+ z_s_seats +] seats ([+ z_s +]%)

Liberty League: House [+ liberty_league_h_seats +] seats ([+ liberty_league_h +]%) / Senate [+ liberty_league_s_seats +] seats ([+ liberty_league_s +]%)

Republican Party: House [+ gop_h_seats +] seats ([+ gop_h +]%) / Senate [+ gop_s_seats +] seats ([+ gop_s +]%)

National Union for Social Justice: House [+ nusj_h_seats +] seats ([+ nusj_h +]%) / Senate [+ nusj_s_seats +] seats ([+ nusj_s +]%)

Silver Legion: House [+ silver_legion_h_seats +] seats ([+ silver_legion_h +]%) / Senate [+ silver_legion_s_seats +] seats ([+ silver_legion_s +]%)

[? if nusj_no_coop = 1 and sla_no_coop = 1 : National Union for Social Justice and Silver Legion-aligned forces are permanently excluded from cooperation with Democratic-led governing coalitions. ?]

[? if gridlock_risk = 1 : No democratic coalition currently has a Senate majority. Even if a House governing coalition forms, legislative gridlock risk is high. ?]

[? if nazi_urgency <= 1 and nsdap_r >= 15 : The rapid rise in Silver Legion votes is extremely worrying. Many had believed that the movement was marginal; now, some of us consider it one of the greatest threats to American democracy. ?]

[? if anti_democratic_coalition >= 50 : Together, anti-system socialists, Republican hardliners, and the National Union for Social Justice have a national majority. A stable governing majority will be almost impossible. ?]

First, organize the House. Senate bargaining comes next; each chamber gets its own coalition menu.

@house_coalition_menu

= House coalition formation

Choose a House organizing coalition. This secures the Speaker and committee control; the Senate still has to be negotiated separately.

- @house_spd_majority
- @house_broad_reform
- @house_stabilization
- @house_left
- @house_popular
- @house_non_dem_coalition

@house_spd_majority
title: Democratic House majority.
subtitle: Democratic Party ([+ spd_h +]%)
view-if: spd_h >= 50
on-arrival: selected_house_coalition = "Democratic majority"; governing_house_support = spd_h; speaker_elected = 1; in_spd_majority = 1;
go-to: senate_results

The Democratic Party can organize the House without outside support.

@house_broad_reform
title: Broad reform House coalition.
subtitle: Democratic Party + Farmer-Labor ([+ weimar_house +]%)
view-if: weimar_house >= 50
on-arrival: selected_house_coalition = "Broad reform coalition"; governing_house_support = weimar_house; speaker_elected = 1;
go-to: senate_results

The House can be organized around the Democratic Party and Farmer-Labor. The Liberty League remains outside this reform bloc, attacking the administration from the right.

@house_stabilization
title: National stabilization House coalition.
subtitle: Democratic Party + Farmer-Labor + Republican Party ([+ grand_house +]%)
view-if: grand_house >= 50
on-arrival: selected_house_coalition = "National stabilization coalition"; governing_house_support = grand_house; speaker_elected = 1;
go-to: senate_results

The House can be organized with a broader cross-party stabilization bloc.

@house_left
title: Labor-left House coalition.
subtitle: Democratic Party + Socialist Party of America [? if sapd_formed: + left splinters ?]([+ left_house +]%)
view-if: left_house >= 50
on-arrival: selected_house_coalition = "Labor-left coalition"; governing_house_support = left_house; speaker_elected = 1;
go-to: senate_results

The House can be organized with Democratic and socialist support.

@house_popular
title: Popular-front House coalition.
subtitle: Democratic Party + Socialist Party of America + Farmer-Labor ([+ popular_house +]%)
view-if: popular_house >= 50
on-arrival: selected_house_coalition = "Popular front coalition"; governing_house_support = popular_house; speaker_elected = 1;
go-to: senate_results

The House can be organized through a broad anti-reactionary coalition.

@house_non_dem_coalition
title: A non-Democratic House majority organizes.
subtitle: [+ non_dem_house_name +] ([+ non_dem_house +]%, [+ non_dem_house_seats +] seats)
view-if: spd_h < 50 and weimar_house < 50 and grand_house < 50 and left_house < 50 and popular_house < 50
on-arrival: selected_house_coalition = non_dem_house_name; governing_house_support = 0; speaker_elected = 0; non_dem_house_control = non_dem_house_has_majority; legislative_gridlock = 1 if non_dem_house_has_majority = 0; chancellor = "Opposition Speaker" if non_dem_house_has_majority = 1; chancellor_party = "DVP" if constitutional_opposition_house >= far_right_house; chancellor_party = "DNVP" if far_right_house > constitutional_opposition_house;
go-to: senate_results

No Democratic-led House coalition can reach a majority. [? if non_dem_house_has_majority = 1 : The largest viable non-Democratic organizing bloc takes the Speaker and committee control by default: ?][? if non_dem_house_has_majority = 0 : No non-Democratic bloc can organize the House either; the chamber is deadlocked around the largest possible bloc: ?]

[+ non_dem_house_desc +].

Would-be non-Democratic blocs: [+ non_dem_house_alternatives +]. Only the strongest realistic bloc may organize the chamber.

@senate_results
on-display: {!
var senateData = [
    {"id": "kpd", "legend": "Socialist Party of America", "name": "Socialist Party of America", "seats": Q.kpd_s_seats},
    {"id": "spd", "legend": "Democratic Party", "name": "Democratic Party", "seats": Q.spd_s_seats},
    {"id": "ddp", "legend": "Liberty League", "name": "Liberty League", "seats": Q.liberty_league_s_seats},
    {"id": "z", "legend": "Farmer-Labor", "name": "Farmer-Labor", "seats": Q.z_s_seats},
    {"id": "dvp", "legend": "Republican Party", "name": "Republican Party", "seats": Q.gop_s_seats},
    {"id": "dnvp", "legend": "National Union for Social Justice", "name": "National Union for Social Justice", "seats": Q.nusj_s_seats},
    {"id": "nsdap", "legend": "Silver Legion", "name": "Silver Legion", "seats": Q.silver_legion_s_seats}
];
if (Q.sapd_formed && Q.sapd_s) {
    senateData.splice(1, 0, {"id": "sapd", "legend": "Left splinters", "name": "Left splinters", "seats": Q.sapd_s_seats});
}
if (window && d3) {
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("senate").style.height = screenWidth/2 + "px";
    }
    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#senate").datum(senateData).call(parliament);
    d3.select("#house_recap").datum([
        {"id": "kpd", "legend": "Socialist Party of America", "name": "Socialist Party of America", "seats": Q.kpd_h_seats},
        {"id": "spd", "legend": "Democratic Party", "name": "Democratic Party", "seats": Q.spd_h_seats},
        {"id": "ddp", "legend": "Liberty League", "name": "Liberty League", "seats": Q.liberty_league_h_seats},
        {"id": "z", "legend": "Farmer-Labor", "name": "Farmer-Labor", "seats": Q.z_h_seats},
        {"id": "dvp", "legend": "Republican Party", "name": "Republican Party", "seats": Q.gop_h_seats},
        {"id": "dnvp", "legend": "National Union for Social Justice", "name": "National Union for Social Justice", "seats": Q.nusj_h_seats},
        {"id": "nsdap", "legend": "Silver Legion", "name": "Silver Legion", "seats": Q.silver_legion_h_seats}
    ]).call(parliament);
}
!}
go-to: coalition_menu

= Senate election results

House organizing coalition: [+ selected_house_coalition +]

