view-if: can_dem_senate_coalition = 0
on-arrival: selected_senate_coalition = non_dem_senate_name; governing_senate_support = 0; bill_coalition_viable = 0; non_dem_senate_control = non_dem_senate_has_majority; non_dem_congressional_control = 1 if non_dem_house_control = 1 and non_dem_senate_has_majority = 1; spd_in_government = 1 if president_party = "SPD"; spd_toleration = 0; in_spd_majority = 0; in_weimar_coalition = 0; in_grand_coalition = 0; in_left_front = 0; in_popular_front = 0; legislative_gridlock = 1; pro_republic -= 2;
