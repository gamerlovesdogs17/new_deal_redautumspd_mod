Q.senate_whip_operation_display = Q.senate_whip_operation || 0;
Q.pork_barrel_pressure_display = Q.pork_barrel_pressure || 0;
Q.capital_strike_display = Math.round((Q.capital_strike_progress || 0) * 10) / 10;
Q.coup_risk_display = Math.round((Q.coup_progress || 0) * 10) / 10;
!}

= Strategic Dashboard

{!<div class="strategic-list">!}
{!<div class="strategic-row">!}{!<span>!}New Deal legitimacy{!</span>!}{!<span>!}[? if new_deal_legitimacy >= 65 : {!<span style="color:#2e7d32;font-weight:bold">!}[+ new_deal_legitimacy_display +]%{!</span>!} ?][? if new_deal_legitimacy < 65 and new_deal_legitimacy >= 40 : {!<span style="color:#b58900;font-weight:bold">!}[+ new_deal_legitimacy_display +]%{!</span>!} ?][? if new_deal_legitimacy < 40 : {!<span style="color:#c62828;font-weight:bold">!}[+ new_deal_legitimacy_display +]%{!</span>!} ?]{!</span>!}{!</div>!}
{!<div class="strategic-row">!}{!<span>!}Economic stress index{!</span>!}{!<span>!}[? if economic_stress <= 6 : {!<span style="color:#2e7d32;font-weight:bold">!}[+ economic_stress_display +]{!</span>!} ?][? if economic_stress > 6 and economic_stress < 12 : {!<span style="color:#b58900;font-weight:bold">!}[+ economic_stress_display +]{!</span>!} ?][? if economic_stress >= 12 : {!<span style="color:#c62828;font-weight:bold">!}[+ economic_stress_display +]{!</span>!} ?]{!</span>!}{!</div>!}
