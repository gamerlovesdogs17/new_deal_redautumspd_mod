@polls
on-arrival: {!
Q.pro_republic_disp = Math.round(Q.pro_republic);
Q.nationalism_disp = Math.round(Q.nationalism);
Q.socialism_disp = Math.round(Q.socialism);
Q.gop_votes = Q.dvp_votes || 0;
Q.liberty_league_votes = Q.ddp_votes || 0;
Q.nusj_votes = Q.dnvp_votes || 0;
Q.silver_legion_votes = Q.nsdap_votes || 0;
for (var c of Q.classes) {
    Q[c + '_gop_display'] = Math.round(Q[c + '_dvp_normalized'] || 0);
    Q[c + '_liberty_league_display'] = Q[c + '_ddp_display'];
    Q[c + '_nusj_display'] = Q[c + '_dnvp_display'];
    Q[c + '_silver_legion_display'] = Q[c + '_nsdap_display'];
}
!}
view-if: game_over

