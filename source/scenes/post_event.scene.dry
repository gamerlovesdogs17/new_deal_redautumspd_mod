title: Post Event
new-page: true
on-arrival: {!
Q.last_advisor_action = 0;
Q.last_cabinet_action = 0;
// make sure no stat is below 0.
for (var c of Q.classes) {
    for (var party of Q.parties) {
        if (Q[c+'_'+party] < 0) {
            Q[c+'_'+party] = 0;
        }
    }
}

Q.pro_republic = Math.round(Q.pro_republic);
Q.nationalism = Math.round(Q.nationalism);
Q.socialism = Math.round(Q.socialism);

if (Q.pro_republic < 0) {
    Q.pro_republic = 0;
}
if (Q.pro_republic >= 100) {
    Q.pro_republic = 99;
}

for (var force of ['rb', 'sh', 'sa', 'rfb']) {
    Q[force + '_strength'] = Math.max(0, Q[force + '_strength'] || 0);
    Q[force + '_militancy'] = Math.max(0, Math.min(1, Q[force + '_militancy'] || 0));
}
for (var force of ['interior_police', 'prussian_police']) {
    Q[force + '_strength'] = Math.max(0, Q[force + '_strength'] || 0);
    Q[force + '_militancy'] = Math.max(0, Q[force + '_militancy'] || 0);
    Q[force + '_loyalty'] = Math.max(0, Math.min(1, Q[force + '_loyalty'] || 0));
}
Q.reichswehr_strength = Math.max(0, Q.reichswehr_strength || 0);
Q.reichswehr_militancy = Math.max(0, Q.reichswehr_militancy || 0);
Q.reichswehr_loyalty = Math.max(0, Math.min(1, Q.reichswehr_loyalty || 0));

// re-calculate party support
// calculate normalized class voting for the achievements
for (var c of Q.classes) {
    var class_votes = 0;
    for (var party of Q.parties) {
        if (Q[c+'_'+party] < 0) {
            Q[c+'_'+party] = 0;
        }
        class_votes += Q[c+'_'+party];
    }
    for (var party of Q.parties) {
        Q[c + '_' + party + '_normalized'] = 100*Q[c+'_'+party]/class_votes;
        Q[c + '_' + party + '_display'] = Math.round(100*Q[c+'_'+party]/class_votes);
    }
}
// calculate support for each of the parties
var total_support = 0; 
for (var party of Q.parties) {
    var party_support = 0;
    for (var c of Q.classes) {
        if (Q.old_demographics) { 
            party_support += Q[c]*Q[c+'_'+party];
        } else  { 
            party_support += Q[c]*Q[c+'_'+party+'_normalized'];
        } 
    }
    Q[party + '_support'] = party_support;
    total_support += party_support; 
}
// 2. normalize support (fraction)
for (var party of Q.parties) {
    Q[party+'_normalized'] = Q[party + '_support']/total_support;
    Q[party+'_votes'] = Math.round(Q[party+'_normalized']*100);
    Q[party+'_votes_display'] = Math.round(Q[party+'_normalized']*100);
}

// Canonical U.S. aliases used by new content. Legacy bloc names remain the
// backing store while scenes are migrated in controlled batches.
Q.dem_votes = Q.spd_votes || 0;
Q.spa_votes = Q.kpd_votes || 0;
Q.fl_votes = Q.z_votes || 0;
Q.liberty_league_votes = Q.ddp_votes || 0;
Q.gop_votes = Q.dvp_votes || 0;
Q.nusj_votes = Q.dnvp_votes || 0;
Q.silver_legion_votes = Q.nsdap_votes || 0;
Q.party_engine_map = {
    "dem": "spd",
    "spa": "kpd",
    "fl": "z",
    "liberty_league": "ddp",
    "gop": "dvp",
    "nusj": "dnvp",
    "silver_legion": "nsdap"
};
Q.party_display_map = {
    "SPD": "Democratic Party",
    "KPD": "Socialist Party of America",
    "SPA": "Socialist Party of America",
    "Z": "Farmer-Labor",
    "DDP": "Liberty League",
    "DVP": "Republican Party",
    "DNVP": "National Union for Social Justice",
    "NSDAP": "Silver Legion",
    "I": "Independent"
};
Q.dem_r = Q.spd_r || Q.dem_votes || 0;
Q.spa_r = Q.kpd_r || Q.spa_votes || 0;
Q.fl_r = Q.z_r || Q.fl_votes || 0;
Q.liberty_league_r = Q.ddp_r || Q.liberty_league_votes || 0;
Q.gop_r = Q.dvp_r || Q.gop_votes || 0;
Q.nusj_r = Q.dnvp_r || Q.nusj_votes || 0;
Q.silver_legion_r = Q.nsdap_r || Q.silver_legion_votes || 0;
Q.fl_relation = Q.z_relation;
Q.spa_relation = Q.kpd_relation;
Q.liberty_league_relation = Q.ddp_relation;
Q.gop_relation = Q.dvp_relation;
Q.nusj_relation = Q.dnvp_relation;
Q.silver_legion_relation = Q.nsdap_relation;
Q.new_deal_liberal_strength = Q.left_strength;
Q.party_regular_strength = Q.center_strength;
Q.labor_dem_strength = Q.labor_strength;
Q.conservative_dem_strength = Q.reformist_strength;
Q.southern_dem_strength = Q.neorevisionist_strength;
Q.new_deal_liberal_dissent = Q.left_dissent;
Q.party_regular_dissent = Q.center_dissent;
Q.labor_dem_dissent = Q.labor_dissent;
Q.conservative_dem_dissent = Q.reformist_dissent;
Q.southern_dem_dissent = Q.neorevisionist_dissent;


// set faction strength/dissent to 0
for (var c of Q.factions) {
    if (Q[c+'_dissent'] < 0) {
        Q[c+'_dissent'] = 0;
    } else if (Q[c+'_dissent'] >= 100) {
        Q[c+'_dissent'] = 99;
    }
    if (Q[c+'_strength'] < 0) {
        Q[c+'_strength'] = 0;
    }
}

if (Q.unemployed <= 1) {
    Q.unemployed = 1;
}

// re-calculate dissent.
var total_strength = Q.left_strength + Q.center_strength + Q.labor_strength + Q.reformist_strength + Q.neorevisionist_strength;

// normalize strength for the different factions
Q.left_strength = 100*Q.left_strength/total_strength;
Q.center_strength = 100*Q.center_strength/total_strength;
Q.labor_strength = 100*Q.labor_strength/total_strength;
Q.reformist_strength = 100*Q.reformist_strength/total_strength;
Q.neorevisionist_strength = 100*Q.neorevisionist_strength/total_strength;
Q.new_deal_liberal_strength = Q.left_strength;
Q.party_regular_strength = Q.center_strength;
Q.labor_dem_strength = Q.labor_strength;
Q.conservative_dem_strength = Q.reformist_strength;
Q.southern_dem_strength = Q.neorevisionist_strength;
Q.new_deal_liberal_dissent = Q.left_dissent;
Q.party_regular_dissent = Q.center_dissent;
Q.labor_dem_dissent = Q.labor_dissent;
Q.conservative_dem_dissent = Q.reformist_dissent;
Q.southern_dem_dissent = Q.neorevisionist_dissent;

var total_dissent = Q.left_strength*Q.left_dissent + Q.center_strength*Q.center_dissent + Q.labor_strength*Q.labor_dissent + Q.reformist_strength*Q.reformist_dissent + Q.neorevisionist_strength*Q.neorevisionist_dissent;


Q.dissent = 0.01*total_dissent/total_strength;
Q.dissent_percent = Q.dissent*100;
console.log('new dissent: ' + Q.dissent);

if (Q.dissent < 0) {
    Q.dissent = 0;
} else if (Q.dissent > 0.95) {
    Q.dissent = 0.95;
}

// 1. update dates
if (Q.month_actions >= 1) {
    Q.time += 1;
    Q.month_actions = 0;
    Q.month += 1;
    if (Q.month >= 13) {
        Q.month = 1;
        Q.year += 1;
        if (Q.historical_mode) {
            Q.resources += 2;
        }
    }
    // decrement timers
    for (timer of Q.timers) {
        if (Q[timer+'_timer'] && Q[timer+'_timer'] > 0) {
            Q[timer+'_timer'] -= 1;
        }
    }
    // append to historical party support records
    var party_support_results = {'date': new Date(Q.year, Q.month - 1)};
    for (var party of Q.parties) {
        party_support_results[party] = Q[party + '_normalized']*100;
    }
    Q.party_support_records.push(party_support_results);
    Q.economic_records.push({'date': new Date(Q.year, Q.month - 1),
                             'inflation': Q.inflation,
                             'unemployment': Q.unemployed});
    // recurring party conferences: Democrats in January, GOP in February, every two years.
    if (Q.year >= 1933 && Q.month == 1) {
        if (!Q.dem_conference_seen || (Q.year - Q.last_dem_conference_year) >= 2) {
            Q.dem_conference_due = 1;
        }
    }
    if (Q.year >= 1933 && Q.month == 2) {
        if (!Q.gop_conference_seen || (Q.year - Q.last_gop_conference_year) >= 2) {
            Q.gop_conference_due = 1;
        }
    }
    // legislative support model: House coalitions for Speaker/governing capacity,
    // Senate coalitions for bill passage and sustained policy throughput.
    // Relations now erode coalition support in each chamber instead of only gating
    // coalition formation menus. The House is more sensitive to party discipline;
    // the Senate is more sensitive to individual allied senators defecting.
    var relationFactor = function(relation, floor, ceiling) {
        var r = relation || 0;
        if (r <= floor) {
            return 0;
        }
        if (r >= ceiling) {
            return 1;
        }
        return (r - floor) / (ceiling - floor);
    };
    var houseAlly = function(votes, relation, floor, ceiling) {
        return (votes || 0) * (0.35 + 0.65 * relationFactor(relation, floor, ceiling));
    };
    var senateAlly = function(votes, relation, floor, ceiling) {
        return (votes || 0) * (0.25 + 0.75 * relationFactor(relation, floor, ceiling));
    };
    var coalitionPenalty = Math.max(0, Q.coalition_dissent || 0) * 0.6;
    var kpdPenalty = Math.max(0, Q.kpd_coalition_dissent || 0) * 0.8;
    var weimarHouseSupport = (Q.spd_h || 0) + houseAlly(Q.z_h, Q.z_relation, 25, 60);
    var weimarSenateSupport = (Q.spd_s || 0) + senateAlly(Q.z_s, Q.z_relation, 30, 65);
    var grandHouseSupport = weimarHouseSupport + houseAlly(Q.dvp_h, Q.dvp_relation, 30, 65) + houseAlly(Q.ddp_h || 0, Q.ddp_relation, 25, 60);
    var grandSenateSupport = weimarSenateSupport + senateAlly(Q.dvp_s, Q.dvp_relation, 35, 70) + senateAlly(Q.ddp_s || 0, Q.ddp_relation, 30, 65);
    var leftHouseSupport = (Q.spd_h || 0) + houseAlly((Q.kpd_h || 0) + (Q.sapd_h || 0), Q.kpd_relation, 35, 70);
    var leftSenateSupport = (Q.spd_s || 0) + senateAlly((Q.kpd_s || 0) + (Q.sapd_s || 0), Q.kpd_relation, 40, 75);
    var popularHouseSupport = (Q.spd_h || 0) + houseAlly((Q.kpd_h || 0) + (Q.sapd_h || 0), Q.kpd_relation, 40, 70) + houseAlly(Q.z_h, Q.z_relation, 40, 70);
    var popularSenateSupport = (Q.spd_s || 0) + senateAlly((Q.kpd_s || 0) + (Q.sapd_s || 0), Q.kpd_relation, 45, 75) + senateAlly(Q.z_s, Q.z_relation, 45, 75);
    Q.effective_weimar_house = Math.max(0, weimarHouseSupport - coalitionPenalty);
    Q.effective_weimar_senate = Math.max(0, weimarSenateSupport - coalitionPenalty);
    Q.effective_grand_house = Math.max(0, grandHouseSupport - coalitionPenalty);
    Q.effective_grand_senate = Math.max(0, grandSenateSupport - coalitionPenalty);
    Q.effective_left_house = Math.max(0, leftHouseSupport - kpdPenalty);
    Q.effective_left_senate = Math.max(0, leftSenateSupport - kpdPenalty);
    Q.effective_popular_house = Math.max(0, popularHouseSupport - coalitionPenalty - kpdPenalty);
    Q.effective_popular_senate = Math.max(0, popularSenateSupport - coalitionPenalty - kpdPenalty);
    Q.governing_house_support = Q.spd_h || 0;
    Q.governing_senate_support = Q.spd_s || 0;
    if (Q.in_weimar_coalition) {
        Q.governing_house_support = Q.effective_weimar_house || Q.weimar_house || Q.weimar_coalition || Q.governing_house_support;
        Q.governing_senate_support = Q.effective_weimar_senate || Q.weimar_senate || Q.weimar_coalition || Q.governing_senate_support;
    } else if (Q.in_grand_coalition) {
        Q.governing_house_support = Q.effective_grand_house || Q.grand_house || Q.grand_coalition || Q.governing_house_support;
        Q.governing_senate_support = Q.effective_grand_senate || Q.grand_senate || Q.grand_coalition || Q.governing_senate_support;
    } else if (Q.in_left_front) {
        Q.governing_house_support = Q.effective_left_house || Q.left_house || Q.left_coalition || Q.governing_house_support;
        Q.governing_senate_support = Q.effective_left_senate || Q.left_senate || Q.left_coalition || Q.governing_senate_support;
    } else if (Q.in_popular_front) {
        Q.governing_house_support = Q.effective_popular_house || Q.popular_house || Q.popular_front_coalition || Q.governing_house_support;
        Q.governing_senate_support = Q.effective_popular_senate || Q.popular_senate || Q.popular_front_coalition || Q.governing_senate_support;
    } else if (Q.in_spd_majority) {
        Q.governing_house_support = Q.spd_h || Q.spd_r;
        Q.governing_senate_support = Q.spd_s || Q.spd_r;
    } else if (Q.spd_toleration) {
        Q.governing_house_support = (Q.effective_weimar_house || Q.weimar_house || Q.neo_weimar_coalition || Q.weimar_coalition || Q.governing_house_support);
        Q.governing_senate_support = (Q.effective_weimar_senate || Q.weimar_senate || Q.neo_weimar_coalition || Q.weimar_coalition || Q.governing_senate_support);
    }
    Q.speaker_party = Q.chancellor_party;
    Q.speaker_party_display = Q.party_display_map[Q.speaker_party] || Q.speaker_party || "";
    Q.speaker_elected = (Q.governing_house_support >= 50) ? 1 : 0;
    Q.bill_coalition_viable = (Q.governing_senate_support >= 50) ? 1 : 0;
    Q.legislative_gridlock = (Q.speaker_elected && Q.bill_coalition_viable) ? 0 : 1;
    Q.dem_presidential_control = (Q.president_party == "SPD" || Q.president_party == "DEM" || Q.president_party == "Democratic Party") ? 1 : 0;
    Q.dem_house_control = (Q.spd_in_government && Q.speaker_elected && Q.speaker_party == "SPD") ? 1 : 0;
    Q.dem_senate_control = (Q.spd_in_government && Q.bill_coalition_viable) ? 1 : 0;
    Q.dem_congress_control = (Q.dem_house_control && Q.dem_senate_control) ? 1 : 0;
    Q.dem_trifecta_control = (Q.dem_presidential_control && Q.dem_congress_control) ? 1 : 0;
    Q.non_dem_house_control = Q.dem_house_control ? 0 : 1;
    Q.non_dem_senate_control = Q.dem_senate_control ? 0 : 1;
    Q.non_dem_congressional_control = (Q.non_dem_house_control || Q.non_dem_senate_control) ? 1 : 0;
    if ((Q.spd_in_government || Q.spd_toleration) && !Q.speaker_elected) {
        Q.resources -= 1;
        Q.pro_republic -= 1;
        Q.center_dissent += 1;
        Q.reformist_dissent += 1;
    }
    if ((Q.spd_in_government || Q.spd_toleration) && Q.speaker_elected && !Q.bill_coalition_viable) {
        Q.resources -= 1;
        Q.economic_growth -= 0.1;
        Q.unemployed += 0.1;
        Q.left_dissent += 1;
        Q.labor_dissent += 1;
    }
    if ((Q.spd_in_government || Q.spd_toleration) && Q.speaker_elected && Q.bill_coalition_viable) {
        if (Q.resources < 8) {
            Q.resources += 1;
        }
        Q.pro_republic += 0.3;
    }
    // U.S. crisis resolver layer. These Q values are the canonical pressure
    // gauges for new scenes; older variables feed them until fully migrated.
    Q.economic_stress = 0;
    if (Q.unemployed > 10) {
        Q.economic_stress += (Q.unemployed - 10) / 2;
    }
    if (Q.economic_growth < 0) {
        Q.economic_stress += Math.abs(Q.economic_growth) / 2;
    }
    if (Q.inflation <= -3) {
        Q.economic_stress += Math.abs(Q.inflation + 3) / 2;
    }
    if (Q.inflation >= 6) {
        Q.economic_stress += (Q.inflation - 6) / 2;
    }
    if (Q.economic_stress > 20) {
        Q.economic_stress = 20;
    }
    Q.labor_militancy = (Q.rb_militancy || 0) * 10 + (Q.cio_momentum || 0) + Math.max(0, (Q.labor_dissent || 0) - 20) / 10;
    Q.conservative_backlash = (Q.capital_strike_progress || 0) + (Q.supreme_court_hostility || 0) + (Q.opposition_pressure || 0);
    Q.conservative_backlash += Math.max(0, 45 - (Q.liberty_league_relation || Q.ddp_relation || 45)) / 10;
    Q.conservative_backlash += Math.max(0, 45 - (Q.gop_relation || Q.dvp_relation || 45)) / 10;
    Q.radical_momentum = (Q.spa_votes || Q.kpd_votes || 0) + (Q.nusj_votes || Q.dnvp_votes || 0) + (Q.silver_legion_votes || Q.nsdap_votes || 0);
    Q.radical_momentum += Math.max(0, Q.economic_stress - 8);
    Q.radical_momentum += Math.max(0, 45 - Q.pro_republic) / 2;
    // U.S. party-shift model inspired by Dynamic Social Democracy: parties
    // accumulate internal pressure from conditions, then elections/conferences
    // read the resulting alignment.
    Q.liberty_league_reform = Q.liberty_league_reform || 0;
    Q.liberty_league_reaction = Q.liberty_league_reaction || 0;
    Q.gop_moderate_pull = Q.gop_moderate_pull || 0;
    Q.gop_reactionary_pull = Q.gop_reactionary_pull || 0;
    Q.farmer_labor_cooperation = Q.farmer_labor_cooperation || 0;
    Q.farmer_labor_left_pull = Q.farmer_labor_left_pull || 0;
    Q.spa_unity_pull = Q.spa_unity_pull || 0;
    Q.spa_opposition_pull = Q.spa_opposition_pull || 0;
    Q.nusj_populist_pull = Q.nusj_populist_pull || 0;
    Q.nusj_authoritarian_pull = Q.nusj_authoritarian_pull || 0;

    Q.liberty_league_reform += Math.max(0, (Q.ddp_relation || 0) - 45) / 80;
    Q.liberty_league_reform += ((Q.dem_economic_plan == "pragmatic_new_deal" || Q.moderate_plan_adopted) ? 0.12 : 0);
    Q.liberty_league_reform += ((Q.pro_republic || 0) >= 65 ? 0.08 : 0);
    Q.liberty_league_reaction += Math.max(0, (Q.capital_strike_progress || 0) - 2) / 12;
    Q.liberty_league_reaction += Math.max(0, (Q.supreme_court_hostility || 0) - 3) / 10;
    Q.liberty_league_reaction += ((Q.dem_economic_plan == "share_our_wealth" || Q.dem_economic_plan == "structural_transformation") ? 0.18 : 0);

    Q.gop_moderate_pull += Math.max(0, (Q.dvp_relation || 0) - 45) / 70;
    Q.gop_moderate_pull += ((Q.gop_wing == "moderate_reform" || Q.gop_economic_plan == "limited_recovery") ? 0.12 : 0);
    Q.gop_moderate_pull += ((Q.new_deal_legitimacy || 0) >= 60 && (Q.economic_stress || 0) <= 8 ? 0.08 : 0);
    Q.gop_reactionary_pull += Math.max(0, (Q.conservative_backlash || 0) - 5) / 12;
    Q.gop_reactionary_pull += Math.max(0, (Q.radio_reach || 0) - 1) / 18;
    Q.gop_reactionary_pull += ((Q.gop_wing == "national_conservative" || Q.gop_economic_plan == "national_retrenchment") ? 0.16 : 0);

    Q.farmer_labor_cooperation += Math.max(0, (Q.z_relation || 0) - 45) / 70;
    Q.farmer_labor_cooperation += ((Q.farm_relief || 0) + (Q.tenant_farmer_support || 0)) / 30;
    Q.farmer_labor_left_pull += Math.max(0, (Q.labor_militancy || 0) - 3) / 12;
    Q.farmer_labor_left_pull += Math.max(0, (Q.kpd_relation || 0) - 45) / 90;
    Q.farmer_labor_left_pull += ((Q.dem_economic_plan == "structural_transformation") ? 0.14 : 0);

    Q.spa_unity_pull += Math.max(0, (Q.kpd_relation || 0) - 40) / 70;
    Q.spa_unity_pull += (Q.dem_spa_cooperation ? 0.2 : 0);
    Q.spa_unity_pull += ((Q.dem_economic_plan == "structural_transformation") ? 0.16 : 0);
    Q.spa_opposition_pull += Math.max(0, 45 - (Q.kpd_relation || 0)) / 90;
    Q.spa_opposition_pull += ((Q.dem_economic_plan == "pragmatic_new_deal" && (Q.economic_stress || 0) >= 10) ? 0.12 : 0);

    Q.nusj_populist_pull += Math.max(0, (Q.economic_stress || 0) - 9) / 16;
    Q.nusj_populist_pull += Math.max(0, (Q.radio_reach || 0) - 1) / 14;
    Q.nusj_authoritarian_pull += Math.max(0, 50 - (Q.pro_republic || 0)) / 70;
    Q.nusj_authoritarian_pull += Math.max(0, (Q.silver_legion_votes || Q.nsdap_votes || 0) - 3) / 18;
    Q.nusj_authoritarian_pull += Math.max(0, (Q.coup_progress || 0) - 3) / 10;

    var clampShift = function(value) {
        return Math.max(0, Math.min(24, value));
    };
    Q.liberty_league_reform = clampShift(Q.liberty_league_reform);
    Q.liberty_league_reaction = clampShift(Q.liberty_league_reaction);
    Q.gop_moderate_pull = clampShift(Q.gop_moderate_pull);
    Q.gop_reactionary_pull = clampShift(Q.gop_reactionary_pull);
    Q.farmer_labor_cooperation = clampShift(Q.farmer_labor_cooperation);
    Q.farmer_labor_left_pull = clampShift(Q.farmer_labor_left_pull);
    Q.spa_unity_pull = clampShift(Q.spa_unity_pull);
    Q.spa_opposition_pull = clampShift(Q.spa_opposition_pull);
    Q.nusj_populist_pull = clampShift(Q.nusj_populist_pull);
    Q.nusj_authoritarian_pull = clampShift(Q.nusj_authoritarian_pull);

    Q.liberty_league_alignment = "business liberal";
    if (Q.liberty_league_reform - Q.liberty_league_reaction >= 4) {
        Q.liberty_league_alignment = "reform liberal";
    } else if (Q.liberty_league_reaction - Q.liberty_league_reform >= 4) {
        Q.liberty_league_alignment = "reactionary business";
    }
    Q.gop_alignment = "old guard";
    if (Q.gop_moderate_pull - Q.gop_reactionary_pull >= 4) {
        Q.gop_alignment = "moderate reform";
    } else if (Q.gop_reactionary_pull - Q.gop_moderate_pull >= 4) {
        Q.gop_alignment = "national conservative";
    }
    Q.farmer_labor_alignment = "independent farm-labor";
    if (Q.farmer_labor_cooperation - Q.farmer_labor_left_pull >= 4) {
        Q.farmer_labor_alignment = "cooperative populist";
    } else if (Q.farmer_labor_left_pull - Q.farmer_labor_cooperation >= 4) {
        Q.farmer_labor_alignment = "labor-left front";
    }
    Q.spa_alignment = "independent socialist";
    if (Q.spa_unity_pull - Q.spa_opposition_pull >= 4) {
        Q.spa_alignment = "unity socialist";
    } else if (Q.spa_opposition_pull - Q.spa_unity_pull >= 4) {
        Q.spa_alignment = "anti-administration socialist";
    }
    Q.nusj_alignment = "radio populist";
    if (Q.nusj_authoritarian_pull - Q.nusj_populist_pull >= 4) {
        Q.nusj_alignment = "authoritarian nationalist";
    } else if (Q.nusj_populist_pull - Q.nusj_authoritarian_pull >= 4) {
        Q.nusj_alignment = "economic populist";
    }
    if (Q.difficulty >= 0 && (Q.spd_in_government || Q.spd_toleration)) {
        if (Q.economic_stress >= 9) {
            Q.new_deal_legitimacy -= 0.2;
            Q.pro_republic -= 0.1;
            Q.radical_momentum += 0.2;
        }
        if (Q.legislative_gridlock) {
            Q.coalition_dissent += 0.1;
        }
        if (Q.governing_house_support < 54 || Q.governing_senate_support < 54) {
            Q.new_deal_legitimacy -= 0.15;
            Q.resources -= 0.1;
        }
    }
    if (Q.difficulty >= 1 && (Q.spd_in_government || Q.spd_toleration)) {
        if (Q.economic_stress >= 8) {
            Q.new_deal_legitimacy -= 0.2;
            Q.left_dissent += 0.2;
            Q.labor_dissent += 0.2;
            Q.economic_growth -= 0.05;
        }
        if (Q.conservative_backlash >= 6) {
            Q.reformist_dissent += 0.2;
            Q.capital_strike_progress += 0.05;
        }
        if ((Q.z_relation || 0) < 35 || (Q.dvp_relation || 0) < 35 || (Q.kpd_relation || 0) < 30) {
            Q.coalition_dissent += 0.15;
        }
    }
    if (Q.spd_in_government || Q.spd_toleration) {
        if (Q.economic_stress >= 10) {
            Q.new_deal_legitimacy -= 0.3;
            Q.left_dissent += 0.3;
            Q.labor_dissent += 0.3;
        }
        if (Q.economic_stress >= 14) {
            Q.workers_kpd += 0.12;
            Q.unemployed_kpd += 0.18;
            Q.unemployed_dnvp += 0.12;
            Q.unemployed_nsdap += 0.12;
            Q.pro_republic -= 0.2;
        }
        if (Q.legislative_gridlock) {
            Q.new_deal_legitimacy -= 0.4;
            Q.center_dissent += 0.3;
            Q.reformist_dissent += 0.3;
        } else if (Q.new_deal_legitimacy < 75 && Q.economic_stress < 10) {
            Q.new_deal_legitimacy += 0.4;
        }
        if (Q.conservative_backlash >= 8) {
            Q.new_middle_dvp += 0.2;
            Q.old_middle_dvp += 0.2;
            Q.reformist_dissent += 0.4;
            Q.capital_strike_progress += 0.1;
        }
        if (Q.labor_militancy >= 6) {
            Q.workers_spd += 0.2;
            Q.workers_kpd += 0.1;
            Q.ddp_relation -= 0.1;
            Q.dvp_relation -= 0.1;
        }
    }
    if (Q.new_deal_legitimacy < 0) {
        Q.new_deal_legitimacy = 0;
    }
    if (Q.new_deal_legitimacy > 100) {
        Q.new_deal_legitimacy = 100;
    }
    var speakerNameMap = {
        "Brüning": "Floyd B. Olson",
        "BrÃ¼ning": "Floyd B. Olson",
        "Wirth": "Henrik Shipstead",
        "Papen": "the conservative caretaker",
        "Schleicher": "the conservative operator",
        "Hitler": "William Pelley",
        "Thälmann": "Norman Thomas",
        "ThÃ¤lmann": "Norman Thomas",
        "Breitscheid": "Fiorello La Guardia",
        "Müller": "Sam Rayburn",
        "MÃ¼ller": "Sam Rayburn"
    };
    Q.speaker = speakerNameMap[Q.chancellor] || Q.chancellor;
    Q.speaker_party = Q.chancellor_party;
    Q.speaker_party_display = Q.party_display_map[Q.speaker_party] || Q.speaker_party || "";
    // change economic stats...
    // we're basically implicity drawing a Philips curve
    // budget deficits lead to some inflation
    if (Q.budget <= 0 && Q.budget > -2 && Q.inflation < 2.5) {
        Q.inflation += 0.1;
    }
    if (Q.budget <= -2 && Q.budget > -5 && Q.inflation < 5) {
        Q.inflation += 0.2;
        if (Q.unemployed >= 12) {
            Q.inflation -= 0.1;
        }
    }
    if (Q.budget <= -5 && Q.inflation < 10) {
        Q.inflation += 0.3;
        if (Q.unemployed >= 15) {
            Q.inflation -= 0.1;
        }
    }
    // deflation is bad
    if (Q.inflation < -0.5 && Q.inflation > -5 && Q.unemployed < 15) {
        Q.unemployed += 0.2;
    }
    if (Q.inflation <= -5 && Q.unemployed < 20) {
        Q.unemployed += 0.3;
    }
    // economic growth
    if (Q.economic_growth < -0.5 && Q.unemployed <= 18) {
        Q.unemployed += 0.1;
    }
    if (Q.economic_growth < -5 && Q.unemployed <= 28) {
        Q.unemployed += 0.1;
    }
    if (Q.economic_growth >= 2 && Q.unemployed >= 17) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 4 && Q.unemployed >= 12) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 6 && Q.unemployed >= 7) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 8 && Q.unemployed >= 3) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 4 && Q.inflation >= 7.5) {
        Q.economic_growth -= 0.1;
    }
    if (Q.economic_growth >= -2.5 && Q.inflation <= -5) {
        Q.economic_growth -= 0.1;
    }
    if (Q.economic_growth >= 7) {
        Q.economic_growth -= 0.1;
    }
    if (Q.economic_growth >= 10) {
        Q.economic_growth -= 0.2;
    }
    if (Q.economic_growth >= 12) {
        Q.economic_growth -= 0.3;
    }

    //////////////////////////////// Education & Science support/economic changes
    if (Q.major_curriculum && Q.major_curriculum == "democratic") {
        if (Q.pro_republic < 60) {
            Q.pro_republic += 0.5;
        } 
    }
    if (Q.minor_curriculum && Q.minor_curriculum == "democratic") {
        if (Q.pro_republic < 60) {
            Q.pro_republic += 0.3;
        } 
    }
    // science bonus to economic growth
    // education bonus
    Q.science_bonus = 0;
    if (Q.education_science) {
        Q.science_bonus += Q.education_science;
    }
    if (Q.science) {
        if (Q.science >= 1) {
            Q.science_bonus += 1;
        } else if (Q.science >= 3) {
            Q.science_bonus += 2;
        } else if (Q.science >= 5) {
            Q.science_bonus += 3;
        }
    }
    if (Q.applied_research && Q.applied_research >= 1) {
        Q.science_bonus += 0.5*Q.applied_research;
    }
    // cap the science bonus at 6
    if (Q.science_bonus > 6) {
        Q.science_bonus = 6;
    }
    console.log(Q.science_bonus);
    // this is kinda messy but basically more science -> higher levels of baseline growth
    if (Q.science_bonus >= 1) {
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus + 3) {
            Q.economic_growth += 0.1;
        }
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus) {
            Q.economic_growth += 0.1;
        }
        if (Q.economic_growth < Q.science_bonus - 3) {
            Q.economic_growth += 0.1;
        }
    }
    // accumulated economic growth/decline
    // Maybe there should be differences for positive/negative growth?
    if (Q.economic_growth < 0) {
        if (Q.economic_expansion > 0) {
            Q.economic_expansion = 0;
        } else {
            Q.economic_expansion += Q.economic_growth;
        }
    }
    if (Q.economic_growth > 0 && Q.reparations <= -2 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth;
    } else if (Q.economic_growth > 0 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth/2;
    }
    /////////////////////////////// update opinions based on economy
    if (Q.unemployed > 15 && Q.pro_republic > 40) {
        Q.pro_republic -= 1;
    }
    if (Q.unemployed > 30 && Q.pro_republic > 20) {
        Q.pro_republic -= 1;
    }
    if (Q.inflation >= 8 && Q.pro_republic > 40) {
        Q.pro_republic -= 1;
    }

    ///////////////////////////// change party support based on pro_republic
    // if pro_republic is less than the support of the Weimar coalition, reduce SPD support...
    if (Q.pro_republic < (Q.spd_votes + Q.ddp_votes + Q.z_votes - 3)) {
        if (Q.new_middle_spd > 0) {
            Q.new_middle_spd -= 5/12;
            Q.new_middle_nsdap += 3/12;
        }
        if (Q.old_middle_spd > 0) {
            Q.old_middle_spd -= 5/12;
            Q.old_middle_nsdap += 3/12;
        }
        if (Q.rural_spd > 0) {
            Q.rural_spd -= 5/12;
            Q.rural_nsdap += 3/12;
        }
        if (Q.workers_spd_normalized > 30) {
            Q.workers_spd -= 4/12;
        }
        if (Q.catholics_spd > 0) {
            Q.catholics_spd -= 4/12;
        }
        if (Q.unemployed_spd_normalized > 10) {
            Q.unemployed_spd -= 4/12;
        }
        if (Q.new_middle_ddp > 0) {
            Q.new_middle_ddp -= 4/12;
            Q.new_middle_nsdap += 3/12;
        }
        if (Q.old_middle_ddp > 0) {
            Q.old_middle_ddp -= 5/12;
            Q.old_middle_nsdap += 4/12;
        }
        if (Q.rural_ddp > 0) {
            Q.rural_ddp -= 5/12;
            Q.rural_nsdap += 4/12;
        }
    }

    ////////////////////////// annual support changes
    if (Q.year == 1929) {
        Q.unemployed += 3/12;
        Q.inflation -= 1/12;
        // increase NSDAP vote share
        Q.new_middle_nsdap += 10/12;
        Q.old_middle_nsdap += 10/12;
        Q.new_middle_ddp -= 5/12;
        Q.new_middle_dvp -= 5/12;
        Q.workers_kpd += 5/12;
        Q.sa_strength += 50/12;
        Q.sh_strength += 100/12;
        Q.rural_dnvp -= 15/12;
        Q.rural_nsdap += 10/12;
        Q.unemployed_nsdap += 18/12;
    } else if (Q.year == 1930) {
        Q.rural_nsdap += 10/12;
        Q.rural_dnvp -= 15/12;
        Q.new_middle_dvp -= 5/12;
        Q.old_middle_dvp -= 6/12;
        Q.new_middle_ddp -= 5/12;
        Q.old_middle_ddp -= 6/12;
        Q.new_middle_nsdap += 10/12;
        Q.old_middle_nsdap += 10/12;
        Q.new_middle_other += 4/12;
        Q.old_middle_other += 4/12;
        Q.unemployed_nsdap += 8/12;
        Q.rural_other += 5/12;

        Q.workers_z += 1/12;
        Q.old_middle_z += 2/12;
        Q.new_middle_z += 2/12;
        if (!Q.works_program) {
            Q.rural_nsdap += 3/12;
            Q.old_middle_nsdap += 5/12;
            Q.workers_nsdap += 2/12;
            Q.workers_other += 5/12;
            Q.workers_kpd += 2/12;
        }
        Q.sa_strength += 100/12;
        Q.sh_strength += 100/12;
    } else if (Q.year == 1931) {
        Q.catholics_z += 2/12;
        Q.rural_dvp -= 8/12;
        Q.old_middle_dvp -= 8/12;
        Q.new_middle_dvp -= 8/12;
        Q.old_middle_ddp -= 8/12;
        Q.new_middle_ddp -= 8/12;
        Q.sa_strength += 50/12;
        Q.sh_strength += 50/12;
        Q.sa_militancy += 0.1/12;
        Q.old_middle_nsdap += 10/12;
        Q.rural_other -= 5/12;
        Q.rural_nsdap += 9/12;
        // TODO: economic policies should reduce NSDAP rurals
        if (!Q.works_program) {
            Q.old_middle_dvp -= 6/12;
            Q.new_middle_dvp -= 6/12;
            Q.rural_dvp -= 6/12;
            Q.workers -= 4/12;
            Q.unemployed_nsdap += 7/12;
            Q.unemployed_kpd += 2/12;
            Q.rural_other -= 12/12;
            Q.rural_nsdap += 12/12;
            Q.new_middle_nsdap += 12/12;
            Q.old_middle_nsdap += 12/12;
            Q.workers_nsdap += 2/12;
            Q.workers_kpd += 4/12;
            Q.sa_strength += 100/12;
            Q.sh_strength += 50/12;
        } else if (Q.unemployed > 15) {
            Q.old_middle_dvp -= 4/12;
            Q.new_middle_dvp -= 4/12;
            Q.rural_dvp -= 4/12;
            Q.unemployed_nsdap += 4/12;
            Q.old_middle_nsdap += 4/12;
            Q.new_middle_nsdap += 4/12;
            Q.rural_nsdap += 4/12;
        }
    } else if (Q.year == 1932) {
        Q.old_middle_other -= 7/12;
        Q.rural_other -= 7/12;
        Q.old_middle_nsdap += 7/12;
        Q.rural_nsdap += 7/12;
        Q.unemployed_nsdap += 4/12;
        if (!Q.works_program) {
            Q.unemployed += 5/12;
            Q.inflation -= 2/12;
            Q.catholics_z += 2/12;
            Q.workers -= 4/12;
            Q.rural_dnvp -= 4/12;
            Q.rural_nsdap += 8/12;
            Q.new_middle_nsdap += 10/12;
            Q.old_middle_nsdap += 10/12;
            Q.unemployed_nsdap += 8/12;
            Q.unemployed_kpd += 2/12;
            Q.workers_nsdap += 3/12;
            Q.workers_kpd += 3/12;
            Q.sa_strength += 200/12;
            Q.new_middle_dnvp += 4/12;
            Q.new_middle_dnvp += 4/12;
            Q.new_middle_dvp -= 4/12;
            Q.old_middle_dvp -= 4/12;
            Q.rural_dvp -= 4/12;
        } else if (Q.unemployed > 25) {
            Q.rural_nsdap += 5/12;
            Q.unemployed_nsdap += 5/12;
            Q.old_middle_nsdap += 5/12;
            Q.new_middle_nsdap += 4/12;
            Q.sa_strength += 50/12;
        } else if (Q.unemployed > 20) {
            Q.rural_nsdap += 2/12;
            Q.unemployed_nsdap += 3/12;
            Q.old_middle_nsdap += 3/12;
            Q.new_middle_nsdap += 2/12;
        }
    } else if (Q.year >= 1933) {
        if (Q.return_to_normalcy) {
            // return to normalcy -> voters return to the base
            if (Q.new_middle_ddp_normalized < 40) {
                Q.new_middle_ddp += 6/12;
            }
            if (Q.new_middle_dvp_normalized < 25) {
                Q.new_middle_dvp += 3/12;
            }
            if (Q.old_middle_dvp_normalized < 40) {
                Q.old_middle_dvp += 6/12;
            }
            if (Q.rural_dnvp_normalized < 40) {
                Q.rural_dnvp += 6/12;
            }
            if (Q.catholics_z_normalized < 40) {
                Q.catholics_z += 6/12;
            }
        }
        if (Q.unemployed > 20) {
            Q.rural_nsdap += 2/12;
            Q.unemployed_nsdap += 2/12;
            Q.old_middle_nsdap += 2/12;
            Q.new_middle_nsdap += 2/12;
            if (Q.spd_in_government) {
                Q.workers_spd -= 4/12;
            }
        }
    }
    // prevent forever support if the economy is bad
    if (Q.year >= 1934 && (Q.inflation >= 8 || Q.unemployed >= 20) && Q.pro_republic <= 45 && Q.spd_in_government) {
        if (Q.workers_spd_normalized > 40) {
            Q.workers_spd -= 6/12;
        }
        if (Q.unemployed_spd_normalized > 20) {
            Q.unemployed_spd -= 6/12;
        }
        if (Q.new_middle_spd_normalized > 20) {
            Q.new_middle_spd -= 6/12;
        }
        if (Q.old_middle_spd_normalized > 20) {
            Q.old_middle_spd -= 6/12;
        }
        if (Q.rural_spd_normalized > 20) {
            Q.rural_spd -= 6/12;
        }
        if (Q.catholics_spd_normalized > 20) {
            Q.catholics_spd -= 6/12;
        }
    }
}
// Minimal pre-event refresh for branch flags used by event view conditions.
Q.dem_presidential_control = (Q.president_party == "SPD" || Q.president_party == "DEM" || Q.president_party == "Democratic Party") ? 1 : 0;
Q.dem_house_control = (Q.spd_in_government && Q.speaker_elected && Q.speaker_party == "SPD") ? 1 : 0;
Q.dem_senate_control = (Q.spd_in_government && Q.bill_coalition_viable) ? 1 : 0;
Q.dem_congress_control = (Q.dem_house_control && Q.dem_senate_control) ? 1 : 0;
Q.dem_trifecta_control = (Q.dem_presidential_control && Q.dem_congress_control) ? 1 : 0;
Q.non_dem_house_control = Q.dem_house_control ? 0 : 1;
Q.non_dem_senate_control = Q.dem_senate_control ? 0 : 1;
Q.non_dem_congressional_control = (Q.non_dem_house_control || Q.non_dem_senate_control) ? 1 : 0;
Q.has_event = 0;
// check if there are any cards in #event, and then go to main if not.
var scene = this.game.scenes['post_event.events_choice'];
var choices = this._compileChoices(scene);
if (choices && choices[0].title != "Continue...") {
    Q.has_event = 1;
} else {
    has_event = 0;
}
// pre-load all of the event images
if (this.ui && this.ui.show_portraits) {
    for (var choice of choices) {
        var cc = this.game.scenes[choice.id];
        if (cc.faceImage) {
            var im = new Image();
            im.url = cc.faceImage;
        }
    }
}

if (typeof window !== "undefined" && window.generateBar) {
}

// Branch control can change during elections or coalition events before the
// next monthly tick. Refresh it here so leadership decks update immediately.
var immediateRelationFactor = function(relation, floor, ceiling) {
    var r = relation || 0;
    if (r <= floor) {
        return 0;
    }
    if (r >= ceiling) {
        return 1;
    }
    return (r - floor) / (ceiling - floor);
};
var immediateHouseAlly = function(votes, relation, floor, ceiling) {
    return (votes || 0) * (0.35 + 0.65 * immediateRelationFactor(relation, floor, ceiling));
};
var immediateSenateAlly = function(votes, relation, floor, ceiling) {
    return (votes || 0) * (0.25 + 0.75 * immediateRelationFactor(relation, floor, ceiling));
};
var immediateCoalitionPenalty = Math.max(0, Q.coalition_dissent || 0) * 0.6;
var immediateKpdPenalty = Math.max(0, Q.kpd_coalition_dissent || 0) * 0.8;
var immediateWeimarHouse = (Q.spd_h || 0) + immediateHouseAlly(Q.z_h, Q.z_relation, 25, 60);
var immediateWeimarSenate = (Q.spd_s || 0) + immediateSenateAlly(Q.z_s, Q.z_relation, 30, 65);
var immediateGrandHouse = immediateWeimarHouse + immediateHouseAlly(Q.dvp_h, Q.dvp_relation, 30, 65) + immediateHouseAlly(Q.ddp_h || 0, Q.ddp_relation, 25, 60);
var immediateGrandSenate = immediateWeimarSenate + immediateSenateAlly(Q.dvp_s, Q.dvp_relation, 35, 70) + immediateSenateAlly(Q.ddp_s || 0, Q.ddp_relation, 30, 65);
var immediateLeftHouse = (Q.spd_h || 0) + immediateHouseAlly((Q.kpd_h || 0) + (Q.sapd_h || 0), Q.kpd_relation, 35, 70);
var immediateLeftSenate = (Q.spd_s || 0) + immediateSenateAlly((Q.kpd_s || 0) + (Q.sapd_s || 0), Q.kpd_relation, 40, 75);
var immediatePopularHouse = (Q.spd_h || 0) + immediateHouseAlly((Q.kpd_h || 0) + (Q.sapd_h || 0), Q.kpd_relation, 40, 70) + immediateHouseAlly(Q.z_h, Q.z_relation, 40, 70);
var immediatePopularSenate = (Q.spd_s || 0) + immediateSenateAlly((Q.kpd_s || 0) + (Q.sapd_s || 0), Q.kpd_relation, 45, 75) + immediateSenateAlly(Q.z_s, Q.z_relation, 45, 75);
Q.effective_weimar_house = Math.max(0, immediateWeimarHouse - immediateCoalitionPenalty);
Q.effective_weimar_senate = Math.max(0, immediateWeimarSenate - immediateCoalitionPenalty);
Q.effective_grand_house = Math.max(0, immediateGrandHouse - immediateCoalitionPenalty);
Q.effective_grand_senate = Math.max(0, immediateGrandSenate - immediateCoalitionPenalty);
Q.effective_left_house = Math.max(0, immediateLeftHouse - immediateKpdPenalty);
Q.effective_left_senate = Math.max(0, immediateLeftSenate - immediateKpdPenalty);
Q.effective_popular_house = Math.max(0, immediatePopularHouse - immediateCoalitionPenalty - immediateKpdPenalty);
Q.effective_popular_senate = Math.max(0, immediatePopularSenate - immediateCoalitionPenalty - immediateKpdPenalty);
Q.governing_house_support = Q.spd_h || 0;
Q.governing_senate_support = Q.spd_s || 0;
if (Q.in_weimar_coalition) {
    Q.governing_house_support = Q.effective_weimar_house || Q.weimar_house || Q.weimar_coalition || Q.governing_house_support;
    Q.governing_senate_support = Q.effective_weimar_senate || Q.weimar_senate || Q.weimar_coalition || Q.governing_senate_support;
} else if (Q.in_grand_coalition) {
    Q.governing_house_support = Q.effective_grand_house || Q.grand_house || Q.grand_coalition || Q.governing_house_support;
    Q.governing_senate_support = Q.effective_grand_senate || Q.grand_senate || Q.grand_coalition || Q.governing_senate_support;
} else if (Q.in_left_front) {
    Q.governing_house_support = Q.effective_left_house || Q.left_house || Q.left_coalition || Q.governing_house_support;
    Q.governing_senate_support = Q.effective_left_senate || Q.left_senate || Q.left_coalition || Q.governing_senate_support;
} else if (Q.in_popular_front) {
    Q.governing_house_support = Q.effective_popular_house || Q.popular_house || Q.popular_front_coalition || Q.governing_house_support;
    Q.governing_senate_support = Q.effective_popular_senate || Q.popular_senate || Q.popular_front_coalition || Q.governing_senate_support;
} else if (Q.in_spd_majority) {
    Q.governing_house_support = Q.spd_h || Q.spd_r;
    Q.governing_senate_support = Q.spd_s || Q.spd_r;
} else if (Q.spd_toleration) {
    Q.governing_house_support = Q.effective_weimar_house || Q.weimar_house || Q.neo_weimar_coalition || Q.weimar_coalition || Q.governing_house_support;
    Q.governing_senate_support = Q.effective_weimar_senate || Q.weimar_senate || Q.neo_weimar_coalition || Q.weimar_coalition || Q.governing_senate_support;
}
Q.speaker_party = Q.chancellor_party;
Q.speaker_party_display = Q.party_display_map[Q.speaker_party] || Q.speaker_party || "";
Q.speaker_elected = (Q.governing_house_support >= 50) ? 1 : 0;
Q.bill_coalition_viable = (Q.governing_senate_support >= 50) ? 1 : 0;
Q.legislative_gridlock = (Q.speaker_elected && Q.bill_coalition_viable) ? 0 : 1;
Q.dem_presidential_control = (Q.president_party == "SPD" || Q.president_party == "DEM" || Q.president_party == "Democratic Party") ? 1 : 0;
Q.dem_house_control = (Q.spd_in_government && Q.speaker_elected && Q.speaker_party == "SPD") ? 1 : 0;
Q.dem_senate_control = (Q.spd_in_government && Q.bill_coalition_viable) ? 1 : 0;
Q.dem_congress_control = (Q.dem_house_control && Q.dem_senate_control) ? 1 : 0;
Q.dem_trifecta_control = (Q.dem_presidential_control && Q.dem_congress_control) ? 1 : 0;
Q.non_dem_house_control = Q.dem_house_control ? 0 : 1;
Q.non_dem_senate_control = Q.dem_senate_control ? 0 : 1;
Q.non_dem_congressional_control = (Q.non_dem_house_control || Q.non_dem_senate_control) ? 1 : 0;
!}
go-to: events_choice if has_event = 1; main if has_event = 0 and difficulty >= 0; main.main_easy if has_event = 0 and difficulty < 0

= [+ month : month +] [+ year +]

@events_choice

- #event

# This scene is solely for updating numbers after events, and routing to special events.
