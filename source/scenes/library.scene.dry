@leaders_factions_us
go-to: menu

= Leaders and faction alignments (U.S. scenario)

This campaign begins in late 1932, after the presidential election but before the governing doctrine of the administration is fully settled. Leadership and faction control can shift over time through party conferences and crisis politics.

**Party leaders at scenario start**

Democratic Party: [+ dem_leader +]
Republican Party: [+ gop_leader +]
Socialist Party of America: [+ spa_leader +]
Farmer-Labor: [+ farmer_labor_leader +]
Liberty League: [+ liberty_league_leader +]
National Union for Social Justice: [+ nusj_leader +]
Silver Legion: [+ sla_leader +]

National Union for Social Justice and Silver Legion-aligned forces are non-cooperative with Democratic-led coalition governance.

**Democratic internal wing leadership**

New Deal Liberals: [+ new_deal_liberal_leader +]
Conservative Democrats: [+ conservative_dem_leader +]
Labor Democrats: [+ labor_dem_leader +]
Southern Democrats: [+ southern_dem_leader +]

**Conference and policy notes**

Democratic and Republican leadership conferences recur on a two-year rhythm. Democratic conference outcomes determine economic direction:

Pragmatic New Deal Reform
Populist Redistribution
Structural Transformation

The Huey Long wildcard can, when selected, reposition Labor Democratic leadership and alter faction dynamics before policy-line selection.

Legislative outcomes now depend on support in both chambers:

House coalition strength affects Speaker formation and government organization.
Senate coalition strength affects bill passage and policy throughput.

@figures
title: Figures and Charts
go-to: menu
on-arrival: z_minus_bvp_r = z_r - 3; gop_r = dvp_r + dnvp_r;
on-display: {!
data = [
    {
        "id": "kpd",
        "legend": "Socialist Party of America",
        "name": "Socialist Party of America",
        "seats": Q.kpd_r*5,
    }];
if (Q.sapd_formed && Q.sapd_r) {
    data.push({
            "id": "sapd",
            "legend": "SAPD",
            "name": "SAPD",
            "seats": Math.round(Q.sapd_r*5),
            });
}
data = data.concat([
    {
        "id": "spd",
        "legend": "Democratic Party",
        "name": "Democratic Party",
        "seats": Q.spd_r*5,
    },
    {
        "id": "ddp",
        "legend": "Liberty League",
        "name": "Liberty League",
        "seats": Q.ddp_r*5,
    },
    {
        "id": "z",
        "legend": "Farmer-Labor",
        "name": "Farmer-Labor",
        "seats": (Q.z_r - 3)*5,
    },
    {
        "id": "bvp",
        "legend": "Farm-Labor allied",
        "name": "Farm-Labor allied",
        "seats": 3*5,
    },
    {
        "id": "dvp",
        "legend": "Republican Party",
        "name": "Republican Party",
        "seats": (Q.dvp_r + Q.dnvp_r)*5,
    },
    {
        "id": "other",
        "legend": "Silver Legion",
        "name": "Silver Legion",
        "seats": Q.other_r*5,
    },
    {
        "id": "nsdap",
        "legend": "National Union for Social Justice",
        "name": "National Union for Social Justice",
        "seats": Q.nsdap_r*5,
    },
]);
if (d3 && window) {
    // get screen width
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    }
    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);

    var lines = d3.linegraph(false, false,
            Q.parties,
            {'spd': '#2f65a8', 'kpd': '#8B0000', 'ddp': '#DCCA4A', 'z': '#000', 'dvp': '#C1121F', 'dnvp': '#C1121F', 'nsdap': '#954B00', 'other': '#a0a0a0', 'sapd': '#c40000'},
            {'spd': 'Democratic Party', 'kpd': 'Socialist Party of America', 'ddp': 'Liberty League', 'z': 'Farmer-Labor', 'dvp': 'Republican moderates', 'dnvp': 'Republican old guard', 'nsdap': 'National Union for Social Justice', 'other': 'Silver Legion', 'sapd': 'Left splinters'});
    lines.width(width).height(400);
    //var svg = lines(Q.election_records);
    if (Q.election_records.length > 0) {
        d3.select("#election_history").datum(Q.election_records).call(lines);
    }
    //document.getElementById('election_history').innerHTML = svg.outerHTML;

    // party support records should not have so many ticks
    if (!Q.historical_mode || Q.game_over) {
        var lines_2 = d3.linegraph(true, true,
            Q.parties,
            {'spd': '#2f65a8', 'kpd': '#8B0000', 'ddp': '#DCCA4A', 'z': '#000', 'dvp': '#C1121F', 'dnvp': '#C1121F', 'nsdap': '#954B00', 'other': '#a0a0a0', 'sapd': '#c40000'},
            {'spd': 'Democratic Party', 'kpd': 'Socialist Party of America', 'ddp': 'Liberty League', 'z': 'Farmer-Labor', 'dvp': 'Republican moderates', 'dnvp': 'Republican old guard', 'nsdap': 'National Union for Social Justice', 'other': 'Silver Legion', 'sapd': 'Left splinters'});
        lines_2.width(width).height(400);
        d3.select("#party_support_history").datum(Q.party_support_records).call(lines_2);
    }

    // economic stats
    var minInflation = d3.min(Q.economic_records, d => d.inflation);
    var maxUnemployment = d3.max(Q.economic_records, d => d.unemployment);
    var lines_3 = d3.linegraph(true, true, ['inflation', 'unemployment'],
            {'inflation': '#0000FF', 'unemployment': '#FF0000'},
            {'inflation': 'Inflation', 'unemployment': 'Unemployment'},
            maxUnemployment + 5, minInflation - 5, 21);
    lines_3.width(width).height(300);
    d3.select("#economic_history").datum(Q.economic_records).call(lines_3);
}
!}

