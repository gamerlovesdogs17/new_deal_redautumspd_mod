subtitle: Industrial workers test how far the New Deal will go.
new-page: true
is-card: true
tags: event
view-if: dem_congress_control and ((year = 1933 and month >= 3) or year > 1933) and news_cooldown_timer = 0 and radical_pressure_timer = 0 and (labor_militancy >= 5 or cio_momentum >= 2 or unemployed >= 18)
max-visits: 1
on-arrival: labor_militancy += 1; cio_momentum += 1; labor_dissent += 2; capital_strike_progress += 1; news_cooldown_timer = 3; radical_pressure_timer = 2
