{!<div class="strategic-row">!}{!<span>!}Court hostility{!</span>!}{!<span>!}[? if supreme_court_hostility <= 2 : {!<span style="color:#2e7d32;font-weight:bold">!}[+ supreme_court_hostility_display +]{!</span>!} ?][? if supreme_court_hostility > 2 and supreme_court_hostility < 5 : {!<span style="color:#b58900;font-weight:bold">!}[+ supreme_court_hostility_display +]{!</span>!} ?][? if supreme_court_hostility >= 5 : {!<span style="color:#c62828;font-weight:bold">!}[+ supreme_court_hostility_display +]{!</span>!} ?]{!</span>!}{!</div>!}
