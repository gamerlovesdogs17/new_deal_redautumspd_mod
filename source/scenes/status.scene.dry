{!<span class="party-spa tooltip-text" tabindex="0" data-tooltip="Socialist Party of America - democratic socialist left opposition.">SPA</span>!}: House [+ spa_h_seats +] seats ([+ spa_h +]%) / Senate [+ spa_s_seats +] seats ([+ spa_s +]%)

{!<span class="party-fl tooltip-text" tabindex="0" data-tooltip="Farmer-Labor - agrarian-labor progressive bloc.">FL</span>!}: House [+ fl_h_seats +] seats ([+ fl_h +]%) / Senate [+ fl_s_seats +] seats ([+ fl_s +]%)

{!<span class="party-liberty tooltip-text" tabindex="0" data-tooltip="Liberty League - anti-New Deal conservative liberal split.">LL</span>!}: House [+ liberty_league_h_seats +] seats ([+ liberty_league_h +]%) / Senate [+ liberty_league_s_seats +] seats ([+ liberty_league_s +]%)

{!<span class="party-gop tooltip-text" tabindex="0" data-tooltip="Republican Party - conservative and moderate anti-New Deal opposition.">GOP</span>!}: House [+ gop_h_seats +] seats ([+ gop_h +]%) / Senate [+ gop_s_seats +] seats ([+ gop_s +]%)

{!<span class="party-nusj tooltip-text" tabindex="0" data-tooltip="National Union for Social Justice - Coughlinite national-populist right.">NUSJ</span>!}: House [+ nusj_h_seats +] seats ([+ nusj_h +]%) / Senate [+ nusj_s_seats +] seats ([+ nusj_s +]%)

{!<span class="party-silver tooltip-text" tabindex="0" data-tooltip="Silver Legion - extremist far-right movement.">SL</span>!}: House [+ silver_legion_h_seats +] seats ([+ silver_legion_h +]%) / Senate [+ silver_legion_s_seats +] seats ([+ silver_legion_s +]%)

