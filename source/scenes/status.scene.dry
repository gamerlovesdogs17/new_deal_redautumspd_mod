on-arrival: {!
Q.banking_confidence_display = Q.banking_confidence || 0;
Q.new_deal_legitimacy_display = Math.round((Q.new_deal_legitimacy || 0) * 10) / 10;
Q.economic_stress_display = Math.round((Q.economic_stress || 0) * 10) / 10;
Q.labor_militancy_display = Math.round((Q.labor_militancy || 0) * 10) / 10;
Q.conservative_backlash_display = Math.round((Q.conservative_backlash || 0) * 10) / 10;
Q.radical_momentum_display = Math.round((Q.radical_momentum || 0) * 10) / 10;
