Q.opposition_pressure_display = Q.opposition_pressure || 0;
Q.liberty_litigation_display = Q.liberty_litigation || 0;
Q.gop_obstruction_display = Q.gop_obstruction || 0;
Q.radio_reach_display = Q.radio_reach || 0;
Q.governor_network_display = Q.governor_network || 0;
Q.farm_relief_display = Q.farm_relief || 0;
Q.agency_capacity_display = Q.agency_capacity || 0;
Q.cabinet_style_display = Q.cabinet_style || "regular";
Q.committee_control_display = Q.committee_control || 0;
