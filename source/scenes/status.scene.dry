title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
if (typeof Q.dnvp_relation === "undefined") {
    Q.dnvp_relation = Q.DNVP_relation || 18;
}
if (typeof Q.nsdap_relation === "undefined") {
    Q.nsdap_relation = Q.NSDAP_relation || 8;
}
if (typeof Q.sla_relation === "undefined") {
    Q.sla_relation = 4;
}
Q.gop_r = Q.dvp_r || 0;
Q.nusj_r = Q.dnvp_r || 0;
Q.silver_legion_r = Q.nsdap_r || 0;
Q.dem_r = Q.spd_r || 0;
Q.spa_r = Q.kpd_r || 0;
Q.fl_r = Q.z_r || 0;
Q.dem_h = Q.spd_h || Q.spd_r || 0;
Q.dem_s = Q.spd_s || Q.spd_r || 0;
Q.spa_h = Q.kpd_h || Q.kpd_r || 0;
Q.spa_s = Q.kpd_s || Q.kpd_r || 0;
Q.fl_h = Q.z_h || Q.z_r || 0;
Q.fl_s = Q.z_s || Q.z_r || 0;
Q.gop_h = Q.dvp_h || Q.dvp_r || 0;
Q.gop_s = Q.dvp_s || Q.dvp_r || 0;
Q.liberty_league_h = Q.ddp_h || Q.ddp_r || 0;
Q.liberty_league_s = Q.ddp_s || Q.ddp_r || 0;
Q.nusj_h = Q.dnvp_h || Q.dnvp_r || 0;
Q.nusj_s = Q.dnvp_s || Q.dnvp_r || 0;
Q.silver_legion_h = Q.nsdap_h || Q.nsdap_r || 0;
Q.silver_legion_s = Q.nsdap_s || Q.nsdap_r || 0;
if (!Q.spd_h_seats) {
    Q.spd_h_seats = Math.round(435 * (Q.spd_h || Q.spd_r || 0) / 100);
    Q.kpd_h_seats = Math.round(435 * (Q.kpd_h || Q.kpd_r || 0) / 100);
    Q.z_h_seats = Math.round(435 * (Q.z_h || Q.z_r || 0) / 100);
    Q.ddp_h_seats = Math.round(435 * (Q.ddp_h || Q.ddp_r || 0) / 100);
    Q.dvp_h_seats = Math.round(435 * (Q.dvp_h || Q.dvp_r || 0) / 100);
    Q.dnvp_h_seats = Math.round(435 * (Q.dnvp_h || Q.dnvp_r || 0) / 100);
    Q.nsdap_h_seats = Math.round(435 * (Q.nsdap_h || Q.nsdap_r || 0) / 100);
    Q.other_h_seats = 435 - Q.spd_h_seats - Q.kpd_h_seats - Q.z_h_seats - Q.ddp_h_seats - Q.dvp_h_seats - Q.dnvp_h_seats - Q.nsdap_h_seats;
}
if (!Q.spd_s_seats) {
    Q.spd_s_seats = Math.round(96 * (Q.spd_s || Q.spd_r || 0) / 100);
    Q.kpd_s_seats = Math.round(96 * (Q.kpd_s || Q.kpd_r || 0) / 100);
    Q.z_s_seats = Math.round(96 * (Q.z_s || Q.z_r || 0) / 100);
    Q.ddp_s_seats = Math.round(96 * (Q.ddp_s || Q.ddp_r || 0) / 100);
    Q.dvp_s_seats = Math.round(96 * (Q.dvp_s || Q.dvp_r || 0) / 100);
    Q.dnvp_s_seats = Math.round(96 * (Q.dnvp_s || Q.dnvp_r || 0) / 100);
    Q.nsdap_s_seats = Math.round(96 * (Q.nsdap_s || Q.nsdap_r || 0) / 100);
    Q.other_s_seats = 96 - Q.spd_s_seats - Q.kpd_s_seats - Q.z_s_seats - Q.ddp_s_seats - Q.dvp_s_seats - Q.dnvp_s_seats - Q.nsdap_s_seats;
}
Q.gop_h_seats = Q.dvp_h_seats || 0;
Q.gop_s_seats = Q.dvp_s_seats || 0;
Q.dem_h_seats = Q.spd_h_seats || 0;
Q.dem_s_seats = Q.spd_s_seats || 0;
Q.spa_h_seats = Q.kpd_h_seats || 0;
Q.spa_s_seats = Q.kpd_s_seats || 0;
Q.fl_h_seats = Q.z_h_seats || 0;
Q.fl_s_seats = Q.z_s_seats || 0;
Q.liberty_league_h_seats = Q.ddp_h_seats || 0;
Q.liberty_league_s_seats = Q.ddp_s_seats || 0;
Q.nusj_h_seats = Q.dnvp_h_seats || 0;
Q.nusj_s_seats = Q.dnvp_s_seats || 0;
Q.silver_legion_h_seats = Q.nsdap_h_seats || 0;
Q.silver_legion_s_seats = Q.nsdap_s_seats || 0;
var economicPlanNames = {
    "undecided": "Undecided",
    "pragmatic_new_deal": "Pragmatic New Deal",
    "share_our_wealth": "Share Our Wealth",
    "structural_transformation": "Structural transformation"
};
var republicanWingNames = {
    "undecided": "Undecided",
    "moderate_reform": "Moderate reform",
    "national_conservative": "National conservative",
    "old_guard": "Old Guard"
};
var republicanEconomicPlanNames = {
    "undecided": "Undecided",
    "limited_recovery": "Limited recovery program",
    "fiscal_orthodoxy": "Fiscal orthodoxy",
    "national_retrenchment": "National retrenchment"
};
var leaderNames = {
    "Landon": "Alf Landon",
    "Fish": "Hamilton Fish",
    "Hoover": "Herbert Hoover"
};
var partyNames = {
    "SPD": "Democratic Party",
    "KPD": "Socialist Party of America",
    "SPA": "Socialist Party of America",
    "Z": "Farmer-Labor",
    "DDP": "Liberty League",
    "DVP": "Republican Party",
    "DNVP": "National Union for Social Justice",
    "NSDAP": "Silver Legion",
    "Silver Legion": "Silver Legion",
    "I": "Independent"
};
var partyTags = {
    dem: '<span class="party-dem tooltip-text" tabindex="0" data-tooltip="Democratic Party - New Deal governing coalition.">DEM</span>',
    spa: '<span class="party-spa tooltip-text" tabindex="0" data-tooltip="Socialist Party of America - democratic socialist left opposition.">SPA</span>',
    fl: '<span class="party-fl tooltip-text" tabindex="0" data-tooltip="Farmer-Labor - agrarian-labor progressive bloc.">FL</span>',
    liberty: '<span class="party-liberty tooltip-text" tabindex="0" data-tooltip="Liberty League - anti-New Deal conservative liberal split.">LL</span>',
    gop: '<span class="party-gop tooltip-text" tabindex="0" data-tooltip="Republican Party - conservative and moderate anti-New Deal opposition.">GOP</span>',
    nusj: '<span class="party-nusj tooltip-text" tabindex="0" data-tooltip="National Union for Social Justice - Coughlinite national-populist right.">NUSJ</span>',
    silver: '<span class="party-silver tooltip-text" tabindex="0" data-tooltip="Silver Legion - extremist far-right movement.">SL</span>'
};
Q.party_dem_tag = partyTags.dem;
Q.party_spa_tag = partyTags.spa;
Q.party_fl_tag = partyTags.fl;
Q.party_liberty_tag = partyTags.liberty;
Q.party_gop_tag = partyTags.gop;
Q.party_nusj_tag = partyTags.nusj;
Q.party_silver_tag = partyTags.silver;
Q.dem_economic_plan_display = economicPlanNames[Q.dem_economic_plan] || "Undecided";
Q.gop_wing_display = republicanWingNames[Q.gop_wing] || "Undecided";
Q.gop_economic_plan_display = republicanEconomicPlanNames[Q.gop_economic_plan] || Q.gop_economic_plan_display || "Undecided";
Q.gop_party_chair_display = leaderNames[Q.gop_party_chair] || Q.gop_party_chair || "undecided";
Q.gop_leader_display = leaderNames[Q.gop_leader] || Q.gop_leader || Q.gop_party_chair_display;
Q.liberty_league_alignment_display = Q.liberty_league_alignment || "business liberal";
Q.gop_alignment_display = Q.gop_alignment || "old guard";
Q.farmer_labor_alignment_display = Q.farmer_labor_alignment || "independent farm-labor";
Q.spa_alignment_display = Q.spa_alignment || "independent socialist";
Q.nusj_alignment_display = Q.nusj_alignment || "radio populist";
Q.liberty_shift_display = Math.round(((Q.liberty_league_reform || 0) - (Q.liberty_league_reaction || 0)) * 10) / 10;
Q.gop_shift_display = Math.round(((Q.gop_moderate_pull || 0) - (Q.gop_reactionary_pull || 0)) * 10) / 10;
Q.fl_shift_display = Math.round(((Q.farmer_labor_cooperation || 0) - (Q.farmer_labor_left_pull || 0)) * 10) / 10;
Q.spa_shift_display = Math.round(((Q.spa_unity_pull || 0) - (Q.spa_opposition_pull || 0)) * 10) / 10;
Q.nusj_shift_display = Math.round(((Q.nusj_populist_pull || 0) - (Q.nusj_authoritarian_pull || 0)) * 10) / 10;
function coloredEstimate(label, color) {
    return '<span style="color:' + color + ';font-weight:bold">' + label + '</span>';
}
function supportEstimate(value) {
    value = value || 0;
    if (value >= 62) return coloredEstimate("secure", "#2e7d32");
    if (value >= 52) return coloredEstimate("workable", "#b58900");
    if (value >= 45) return coloredEstimate("fragile", "#d97706");
    return coloredEstimate("failing", "#c62828");
}
function pressureEstimate(value, guarded, high, critical) {
    value = value || 0;
    if (value >= critical) return coloredEstimate("critical", "#c62828");
    if (value >= high) return coloredEstimate("high", "#d97706");
    if (value >= guarded) return coloredEstimate("guarded", "#b58900");
    return coloredEstimate("low", "#2e7d32");
}
function trendStrength(value) {
    value = Math.abs(value || 0);
    if (value >= 10) return "strong";
    if (value >= 5) return "clear";
    if (value >= 2) return "soft";
    return "uncertain";
}
Q.governing_house_support_estimate = supportEstimate(Q.governing_house_support);
Q.governing_senate_support_estimate = supportEstimate(Q.governing_senate_support);
Q.coalition_discipline_estimate = pressureEstimate(Q.coalition_dissent, 2, 3, 4);
Q.kpd_coalition_discipline_estimate = pressureEstimate(Q.kpd_coalition_dissent, 2, 3, 4);
Q.internal_discipline_estimate = pressureEstimate(Q.dissent_percent, 15, 31, 50);
Q.liberty_shift_confidence = trendStrength(Q.liberty_shift_display);
Q.gop_shift_confidence = trendStrength(Q.gop_shift_display);
Q.fl_shift_confidence = trendStrength(Q.fl_shift_display);
Q.spa_shift_confidence = trendStrength(Q.spa_shift_display);
Q.nusj_shift_confidence = trendStrength(Q.nusj_shift_display);
Q.chancellor_party_display = partyNames[Q.chancellor_party] || Q.chancellor_party || "";
var speakerNameMap = {
    "Brüning": "Floyd B. Olson",
    "BrÃ¼ning": "Floyd B. Olson",
    "Wirth": "Henrik Shipstead",
    "Papen": "the conservative caretaker",
    "Schleicher": "the conservative operator",
    "Hitler": "William Pelley",
    "Thälmann": "Norman Thomas",
    "ThÃ¤lmann": "Norman Thomas",
    "Breitscheid": "Fiorello La Guardia",
    "Müller": "Sam Rayburn",
    "MÃ¼ller": "Sam Rayburn"
};
Q.speaker = speakerNameMap[Q.chancellor] || Q.chancellor;
Q.speaker_party = Q.chancellor_party;
Q.speaker_party_display = partyNames[Q.speaker_party] || Q.speaker_party || "";
!}

= Status

[+ month : month +] [+ year +]

{!<div class="status-grid">!}
{!<span class="status-pill">!}Date: [+ month : month +] [+ year +]{!</span>!}
{!<span class="status-pill">!}Political capital: [+ resources +]{!</span>!}
{!<span class="status-pill danger">!}Unemployment: [+ unemployed_2 +]%{!</span>!}
{!<span class="status-pill danger">!}Growth: [+ economic_growth_2 +]%{!</span>!}
{!</div>!}

Democratic position: [? if spd_toleration : external support ?][? if dem_presidential_control and spd_in_government : governing - ?][? if not dem_presidential_control and dem_congress_control : congressional majority - opposition presidency ?][? if not dem_presidential_control and not dem_congress_control and spd_in_government : congressional bloc - opposition presidency ?][? if spd_toleration == 0 and spd_in_government == 0 and spd_caretaker == 0 : opposition ?][? if spd_caretaker : caretaker administration ?]
[? if in_weimar_coalition and spd_in_government: broad reform coalition ?][? if in_grand_coalition and spd_in_government: unity coalition ?][? if in_popular_front and spd_in_government: labor-progressive front ?][? if in_left_front and spd_in_government: left coalition ?][? if in_spd_majority and spd_in_government: Democratic majority ?][? if in_minority_government and spd_in_government: minority government ?][? if in_emergency_government and spd_in_government: emergency government ?]

[? if spd_in_government and not in_spd_majority and not in_left_front : Coalition discipline: [+ coalition_discipline_estimate +] dissent ?]

[? if spd_in_government and (in_left_front or in_popular_front): Socialist Party coalition discipline: [+ kpd_coalition_discipline_estimate +] dissent ?]

Internal coalition discipline: [+ internal_discipline_estimate +]

Democratic economic direction: [+ dem_economic_plan_display +]

Republican orientation: [+ gop_wing_display +] (chair: [+ gop_party_chair_display +])

Republican economic program: [+ gop_economic_plan_display +]

Governing House support: [+ governing_house_support_estimate +]

Governing Senate support: [+ governing_senate_support_estimate +]

House control: [? if non_dem_house_control = 1 : opposition ?][? if non_dem_house_control = 0 : Democratic-led ?]

Senate control: [? if non_dem_senate_control = 1 : opposition ?][? if non_dem_senate_control = 0 : Democratic-led ?]

Speaker secured: [? if speaker_elected = 1 : yes ?][? if speaker_elected = 0 : no ?]

Bill coalition viable: [? if bill_coalition_viable = 1 : yes ?][? if bill_coalition_viable = 0 : no ?]

