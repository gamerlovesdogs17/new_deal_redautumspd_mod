{!<div class="strategic-row">!}{!<span>!}Conservative backlash index{!</span>!}{!<span>!}[? if conservative_backlash <= 4 : {!<span style="color:#2e7d32;font-weight:bold">!}[+ conservative_backlash_display +]{!</span>!} ?][? if conservative_backlash > 4 and conservative_backlash < 8 : {!<span style="color:#b58900;font-weight:bold">!}[+ conservative_backlash_display +]{!</span>!} ?][? if conservative_backlash >= 8 : {!<span style="color:#c62828;font-weight:bold">!}[+ conservative_backlash_display +]{!</span>!} ?]{!</span>!}{!</div>!}
{!<div class="strategic-row">!}{!<span>!}Radical momentum index{!</span>!}{!<span>!}[? if radical_momentum <= 10 : {!<span style="color:#2e7d32;font-weight:bold">!}[+ radical_momentum_display +]{!</span>!} ?][? if radical_momentum > 10 and radical_momentum < 20 : {!<span style="color:#b58900;font-weight:bold">!}[+ radical_momentum_display +]{!</span>!} ?][? if radical_momentum >= 20 : {!<span style="color:#c62828;font-weight:bold">!}[+ radical_momentum_display +]{!</span>!} ?]{!</span>!}{!</div>!}
{!<div class="strategic-row">!}{!<span>!}Banking confidence{!</span>!}{!<span>!}[? if banking_confidence_display >= 55 : {!<span style="color:#2e7d32;font-weight:bold">!}[+ banking_confidence_display +]{!</span>!} ?][? if banking_confidence_display < 55 and banking_confidence_display >= 35 : {!<span style="color:#b58900;font-weight:bold">!}[+ banking_confidence_display +]{!</span>!} ?][? if banking_confidence_display < 35 : {!<span style="color:#c62828;font-weight:bold">!}[+ banking_confidence_display +]{!</span>!} ?]{!</span>!}{!</div>!}
{!<div class="strategic-row">!}{!<span>!}Agency capacity{!</span>!}{!<span>!}[+ agency_capacity_display +]{!</span>!}{!</div>!}
