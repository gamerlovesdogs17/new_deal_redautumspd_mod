title: News: Silver Legion Rally
subtitle: Uniforms and threats move from rumor to spectacle.
new-page: true
is-card: true
tags: event
view-if: ((year = 1933 and month >= 3) or year > 1933) and news_cooldown_timer = 0 and (nsdap_votes >= 5 or sa_strength >= 250 or coup_progress >= 4)
